---
interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="faq-accordion space-y-4">
  {items.map((item) => (
    <details class="group rounded-lg border border-navy-200 overflow-hidden">
      <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-base font-semibold select-none text-navy-900 hover:bg-navy-50 transition-colors">
        {item.question}
        <svg class="w-5 h-5 flex-shrink-0 text-navy-400 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </summary>
      <div class="px-6 pb-5 text-navy-700 leading-relaxed text-sm border-t border-navy-100 pt-4" set:html={item.answer} />
    </details>
  ))}
</div>
