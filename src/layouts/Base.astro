---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
const siteUrl = "https://oteria-conseil.fr";
const fullTitle = title.includes("Oteria") ? title : `${title} – Oteria Conseil`;
const canonical = canonicalPath ? `${siteUrl}${canonicalPath}` : Astro.url.href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logos/icons/icon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#102a43" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Oteria Conseil" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <style>
      .placeholder-err::placeholder { color: #e53e3e !important; opacity: 1 !important; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-navy-200 bg-white sticky top-0 z-50">
      <nav class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center no-underline">
          <img src="/logos/logo-primary.svg" alt="Oteria Conseil" width="145" height="48" class="h-12 w-auto" />
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-navy-700">
          <!-- Expertises mega-menu -->
          <div class="relative" data-dropdown="expertises">
            <button type="button" class="flex items-center gap-1 hover:text-gold-700 no-underline bg-transparent border-none cursor-pointer text-sm font-medium text-navy-700" aria-expanded="false" aria-haspopup="true">
              Expertises
              <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="absolute top-full left-0 mt-2 rounded-lg shadow-xl border border-navy-100 bg-white opacity-0 invisible translate-y-2 transition-all duration-200 pointer-events-none z-50" data-dropdown-panel style="width: 520px;">
              <div class="flex">
                <!-- Left: solutions list -->
                <div class="w-52 py-2 border-r border-navy-100" data-mega-list>
                  <a href="/expertises/" class="block px-4 py-2.5 text-sm no-underline hover:bg-navy-50 font-semibold" style="color: #243b53;">Toutes nos expertises</a>
                  <div class="border-t border-navy-100 my-1"></div>
                  <div class="mega-item px-4 py-2 text-sm no-underline cursor-pointer rounded-r-none transition-colors" style="color: #486581;" data-mega-trigger="pac"><a href="/expertises/pompe-a-chaleur/" class="flex items-center justify-between no-underline w-full" style="color: inherit;">Pompe à chaleur <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a></div>
                  <div class="mega-item px-4 py-2 text-sm no-underline cursor-pointer rounded-r-none transition-colors" style="color: #486581;" data-mega-trigger="isolation"><a href="/expertises/isolation-thermique/" class="flex items-center justify-between no-underline w-full" style="color: inherit;">Isolation thermique <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a></div>
                  <div class="mega-item px-4 py-2 text-sm no-underline cursor-pointer rounded-r-none transition-colors" style="color: #486581;" data-mega-trigger="vmc"><a href="/expertises/vmc-double-flux/" class="flex items-center justify-between no-underline w-full" style="color: inherit;">VMC double flux <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a></div>
