---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
const siteUrl = "https://oteria-conseil.fr";
const fullTitle = title.includes("Oteria") ? title : `${title} – Oteria Conseil`;
const canonical = canonicalPath ? `${siteUrl}${canonicalPath}` : Astro.url.href;
---

<!doctype html>
<html lang="fr">
