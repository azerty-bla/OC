                  <div class="mega-item px-4 py-2 text-sm no-underline cursor-pointer rounded-r-none transition-colors" style="color: #486581;" data-mega-trigger="destrat"><a href="/expertises/destratificateur/" class="flex items-center justify-between no-underline w-full" style="color: inherit;">Destratificateur <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a></div>
