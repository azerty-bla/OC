    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // === Desktop dropdowns (hover) ===
        const dropdowns = document.querySelectorAll('[data-dropdown]');
        dropdowns.forEach((dropdown) => {
          const btn = dropdown.querySelector('button');
          const panel = dropdown.querySelector('[data-dropdown-panel]');
          const chevron = btn?.querySelector('svg');
          let timeout: ReturnType<typeof setTimeout>;

          function open() {
            clearTimeout(timeout);
            panel?.classList.remove('opacity-0', 'invisible', 'translate-y-2', 'pointer-events-none');
            panel?.classList.add('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
            btn?.setAttribute('aria-expanded', 'true');
            if (chevron) chevron.style.transform = 'rotate(180deg)';
          }

          function close() {
            timeout = setTimeout(() => {
              panel?.classList.add('opacity-0', 'invisible', 'translate-y-2', 'pointer-events-none');
              panel?.classList.remove('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
              btn?.setAttribute('aria-expanded', 'false');
              if (chevron) chevron.style.transform = '';
            }, 150);
          }

          dropdown.addEventListener('mouseenter', open);
          dropdown.addEventListener('mouseleave', close);
          btn?.addEventListener('focus', open);
          panel?.addEventListener('focusin', () => clearTimeout(timeout));
          panel?.addEventListener('focusout', close);
        });

        // === Mobile menu ===
        const burgerBtn = document.getElementById('burger-btn');
        const closeBtn = document.getElementById('mobile-close-btn');
        const mobilePanel = document.getElementById('mobile-panel');
        const mobileOverlay = document.getElementById('mobile-overlay');
        const burgerBars = burgerBtn?.querySelectorAll('.burger-bar') as NodeListOf<HTMLElement>;

        function openMobile() {
          mobilePanel!.style.transform = 'translateX(0)';
          mobilePanel!.removeAttribute('inert');
          mobilePanel!.setAttribute('aria-hidden', 'false');
          mobileOverlay!.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
          mobileOverlay!.classList.add('opacity-100', 'visible', 'pointer-events-auto');
          mobileOverlay!.setAttribute('aria-hidden', 'false');
          burgerBtn!.setAttribute('aria-expanded', 'true');
          burgerBtn!.setAttribute('aria-label', 'Fermer le menu');
          document.body.classList.add('overflow-hidden');

          // Animate burger to X
          if (burgerBars.length === 3) {
            burgerBars[0].style.top = '20px';
            burgerBars[0].style.transform = 'rotate(45deg)';
            burgerBars[1].style.opacity = '0';
            burgerBars[2].style.top = '20px';
            burgerBars[2].style.transform = 'rotate(-45deg)';
          }

          // Focus trap
          setupFocusTrap();
        }

        function closeMobile() {
          mobilePanel!.style.transform = 'translateX(100%)';
          mobilePanel!.setAttribute('inert', '');
          mobilePanel!.setAttribute('aria-hidden', 'true');
          mobileOverlay!.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          mobileOverlay!.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
          mobileOverlay!.setAttribute('aria-hidden', 'true');
          burgerBtn!.setAttribute('aria-expanded', 'false');
          burgerBtn!.setAttribute('aria-label', 'Ouvrir le menu');
          document.body.classList.remove('overflow-hidden');

          // Animate X back to burger
          if (burgerBars.length === 3) {
            burgerBars[0].style.top = '14px';
            burgerBars[0].style.transform = '';
            burgerBars[1].style.opacity = '1';
            burgerBars[2].style.top = '26px';
            burgerBars[2].style.transform = '';
          }

          removeFocusTrap();
        }

        burgerBtn?.addEventListener('click', () => {
          const isOpen = burgerBtn.getAttribute('aria-expanded') === 'true';
          isOpen ? closeMobile() : openMobile();
        });

        closeBtn?.addEventListener('click', closeMobile);
        mobileOverlay?.addEventListener('click', closeMobile);

        // Escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && burgerBtn?.getAttribute('aria-expanded') === 'true') {
            closeMobile();
            burgerBtn?.focus();
          }
        });

        // === Focus trap ===
        let focusTrapHandler: ((e: KeyboardEvent) => void) | null = null;

        function setupFocusTrap() {
          focusTrapHandler = (e: KeyboardEvent) => {
            if (e.key !== 'Tab') return;
            const focusable = mobilePanel!.querySelectorAll<HTMLElement>(
              'a[href], button, [tabindex]:not([tabindex="-1"])'
            );
            const first = focusable[0];
            const last = focusable[focusable.length - 1];

            if (e.shiftKey && document.activeElement === first) {
              e.preventDefault();
              last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
              e.preventDefault();
              first.focus();
            }
          };
          document.addEventListener('keydown', focusTrapHandler);
        }

        function removeFocusTrap() {
          if (focusTrapHandler) {
            document.removeEventListener('keydown', focusTrapHandler);
            focusTrapHandler = null;
          }
        }

        // === Mobile accordions ===
        const accordionBtns = document.querySelectorAll<HTMLButtonElement>('[data-accordion]');
        accordionBtns.forEach((btn) => {
          const panelId = btn.getAttribute('data-accordion')!;
          const panel = document.querySelector(`[data-accordion-panel="${panelId}"]`) as HTMLElement;
          const chevron = btn.querySelector('svg') as SVGElement;

          btn.addEventListener('click', () => {
            const isOpen = btn.getAttribute('aria-expanded') === 'true';
            if (isOpen) {
              panel.style.maxHeight = '0';
              btn.setAttribute('aria-expanded', 'false');
              chevron.style.transform = '';
            } else {
              panel.style.maxHeight = panel.scrollHeight + 'px';
              btn.setAttribute('aria-expanded', 'true');
              chevron.style.transform = 'rotate(180deg)';
            }
          });
        });
      });
    </script>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const forms = document.querySelectorAll('form');

        function getMsg(field: HTMLInputElement | HTMLTextAreaElement): string {
          const v = field.validity;
          if (v.valueMissing) return 'Ce champ est requis.';
          if (v.typeMismatch && field.type === 'email') return 'Adresse email invalide.';
          if (v.typeMismatch || v.patternMismatch) return 'Format invalide.';
          return 'Ce champ est invalide.';
        }

        function wrap(field: HTMLInputElement | HTMLTextAreaElement) {
          if (field.parentElement?.classList.contains('field-wrap')) return;
          const wrapper = document.createElement('div');
          wrapper.className = 'field-wrap';
          wrapper.style.cssText = 'position:relative;';
          field.parentNode!.insertBefore(wrapper, field);
          wrapper.appendChild(field);
        }

        function isCompact(field: HTMLElement): boolean {
          return !!field.closest('#hero-form, .hero-form');
        }

        function showError(field: HTMLInputElement | HTMLTextAreaElement) {
          field.style.borderColor = '#e53e3e';
          field.style.boxShadow = '0 0 0 1px #e53e3e';

          if (isCompact(field)) {
            if (!field.dataset.origPlaceholder) field.dataset.origPlaceholder = field.placeholder;
            field.placeholder = getMsg(field);
            field.style.setProperty('--tw-placeholder-opacity', '1');
            field.classList.add('placeholder-err');
          } else {
            wrap(field);
            let errEl = field.parentElement!.querySelector('.field-error') as HTMLElement | null;
            if (!errEl) {
              errEl = document.createElement('span');
              errEl.className = 'field-error';
              errEl.style.cssText = 'color:#e53e3e;font-size:0.7rem;position:absolute;left:0.25rem;bottom:-0.85rem;line-height:1;pointer-events:none;white-space:nowrap;';
              field.parentElement!.appendChild(errEl);
            }
            errEl.textContent = getMsg(field);
          }
        }

        function clearError(field: HTMLInputElement | HTMLTextAreaElement) {
          field.style.borderColor = '';
          field.style.boxShadow = '';

          if (isCompact(field) && field.dataset.origPlaceholder) {
            field.placeholder = field.dataset.origPlaceholder;
            delete field.dataset.origPlaceholder;
            field.classList.remove('placeholder-err');
          } else {
            const errEl = field.parentElement?.querySelector('.field-error');
            if (errEl) errEl.remove();
          }
        }

        forms.forEach((form) => {
          form.setAttribute('novalidate', '');
          form.style.overflow = 'visible';

          form.addEventListener('submit', (e) => {
            const fields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea');
            let firstInvalid: HTMLElement | null = null;

            fields.forEach((field) => {
              if (!field.checkValidity()) {
                showError(field);
                if (!firstInvalid) firstInvalid = field;
              } else {
                clearError(field);
              }
            });

            if (firstInvalid) {
              e.preventDefault();
              firstInvalid.focus();
            }
          });

          form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((field) => {
            field.addEventListener('blur', () => {
              if (!field.checkValidity()) showError(field);
              else clearError(field);
            });
            field.addEventListener('input', () => {
              if (field.checkValidity()) clearError(field);
            });
          });
        });
      });
    </script>
  </body>
</html>
