.hub-step__body li {
  position: relative; padding-left: 1.125rem;
  font-size: .8125rem; color: #486581; margin-bottom: .375rem; line-height: 1.6;
}
.hub-step__body li::before {
  content: ""; position: absolute;
  left: 0; top: .6em; width: 5px; height: 5px;
  border-radius: 50%; background: #d4a024;
}

/* Notice interne (ex. : avertissement) */
.hub-step__notice {
  display: flex; align-items: flex-start; gap: .5rem;
  padding: .5rem .875rem; border-radius: .375rem;
  font-size: .75rem; font-weight: 600;
  margin-top: .75rem; line-height: 1.5;
}
.hub-step__notice--warn {
