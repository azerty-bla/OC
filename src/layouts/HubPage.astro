}
.hub-strip__hl { display: block; color: #102a43; font-size: .9375rem; font-weight: 700; }
.hub-strip__sub { display: block; color: #486581; font-size: .8125rem; margin-top: .2rem; }
.hub-strip__btn {
  display: inline-flex; align-items: center; gap: .5rem;
