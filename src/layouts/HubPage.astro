  border: 1px solid #e4ecf5; border-radius: .5rem;
  font-size: .8125rem; color: #334e68; line-height: 1.55;
  transition: border-color .12s;
}
.hub-doc-list li:hover { border-color: rgba(212,160,36,.4); }
.hub-doc-list li::before {
  content: "✓";
  display: flex; align-items: center; justify-content: center;
  min-width: 1.25rem; width: 1.25rem; height: 1.25rem;
  border-radius: 50%; background: #276749; /* #fff sur #276749 = 6:1 ✓ */ color: #fff;
  font-size: .625rem; font-weight: 900; flex-shrink: 0; margin-top: .05rem;
}


/* ── MID-PAGE CTA STRIP ── */
.hub-strip {
  background: #f0f4f8;
  border-top: 1.5px solid #d9e2ec; border-bottom: 1.5px solid #d9e2ec;
