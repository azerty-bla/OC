/* ── FOOTER CTA ── */
.hub-fcta { background: #102a43; padding-block: 5rem; }
.hub-fcta__inner {
  display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start;
}
@media (min-width: 1024px) { .hub-fcta__inner { grid-template-columns: 1.2fr .8fr; gap: 5rem; } }

.hub-fcta__eyebrow {
  font-size: .6875rem; font-weight: 700; letter-spacing: .14em;
  text-transform: uppercase; color: #d4a024; margin: 0 0 .75rem;
}
.hub-fcta__title {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 2.2vw, 2.125rem); font-weight: 900; color: #fff;
  letter-spacing: -.02em; margin: 0 0 .75rem; line-height: 1.15;
}
.hub-fcta__desc { color: #9fb3c8; font-size: 1rem; line-height: 1.7; margin: 0 0 2rem; }

.hub-fcta__steps { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.125rem; }
.hub-fcta__steps li { display: flex; align-items: flex-start; gap: 1rem; }

.hub-fcta__n {
  display: flex; align-items: center; justify-content: center;
  width: 1.875rem; height: 1.875rem; border-radius: 50%;
  background: rgba(212,160,36,.12); border: 1.5px solid rgba(212,160,36,.35);
  color: #f5c04a; font-size: .75rem; font-weight: 800; flex-shrink: 0;
  font-family: var(--font-heading);
}
.hub-fcta__steps li > div { display: flex; flex-direction: column; gap: .125rem; padding-top: .2rem; }
.hub-fcta__steps li strong { font-size: .9375rem; font-weight: 700; color: #fff; }
.hub-fcta__steps li span { font-size: .8rem; color: #829ab1; line-height: 1.5; }

/* Carte formulaire footer — reprend les styles hub-fc */
.hub-fcta__card {
  background: #fff;
  border-radius: .75rem;
  overflow: hidden;
  box-shadow: 0 32px 80px rgba(0,0,0,.25), 0 0 0 1px rgba(255,255,255,.06);
}


/* ── STICKY BAR ── */
.hub-sticky {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 40;
  background: #243b53; border-top: 1px solid rgba(255,255,255,.08);
  transform: translateY(100%); transition: transform .3s cubic-bezier(.4,0,.2,1);
}
.hub-sticky.is-visible { transform: translateY(0); }

.hub-sticky__inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: 1.5rem; padding-block: .875rem;
}
.hub-sticky__inner p { font-size: .875rem; color: #d9e2ec; margin: 0; display: none; }
@media (min-width: 640px) { .hub-sticky__inner p { display: block; } }

.hub-sticky__hl { color: #f5c04a; font-weight: 700; }
.hub-sticky__btn {
  display: inline-flex; align-items: center;
  padding: .625rem 1.25rem; background: #d4a024; color: #102a43;
  font-size: .875rem; font-weight: 700; border-radius: .375rem;
  text-decoration: none; white-space: nowrap; transition: background .15s;
}
.hub-sticky__btn:hover { background: #f5c04a; }
</style>


<script>
  document.addEventListener("DOMContentLoaded", () => {
    const sticky = document.getElementById("hub-sticky");
    const heroForm = document.getElementById("hero-form");
    const footer = document.querySelector("footer");
    if (!sticky || !heroForm) return;

    const show = () => {
      sticky.classList.add("is-visible");
      sticky.setAttribute("aria-hidden", "false");
      (sticky.querySelector(".hub-sticky__btn") as HTMLElement)?.removeAttribute("tabindex");
    };
    const hide = () => {
      sticky.classList.remove("is-visible");
      sticky.setAttribute("aria-hidden", "true");
      (sticky.querySelector(".hub-sticky__btn") as HTMLElement)?.setAttribute("tabindex", "-1");
    };

    new IntersectionObserver(
      entries => entries.forEach(e => (e.isIntersecting ? hide() : show())),
      { threshold: 0.3 }
    ).observe(heroForm);

    if (footer) {
      new IntersectionObserver(
        entries => entries.forEach(e => { if (e.isIntersecting) hide(); }),
        { threshold: 0.2 }
      ).observe(footer);
    }
  });
</script>
