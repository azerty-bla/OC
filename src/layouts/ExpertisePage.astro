---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  keyword: string;
  cluster: string;
  breadcrumb: { label: string; href: string }[];
  relatedPages?: { title: string; href: string; description: string }[];
  journeyPages?: { label: string; href: string }[];
}

const { title, description, canonical, keyword, cluster, breadcrumb, relatedPages = [], journeyPages = [] } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = "https://oteria-conseil.fr";
const pageUrl = `${siteUrl}${canonical}`;
const fullTitle = title.includes("Oteria") ? title : `${title} – Oteria Conseil`;
const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `${siteUrl}/` },
  ...breadcrumb.map((item, i) => ({ "@type": "ListItem", "position": i + 2, "name": item.label, "item": `${siteUrl}${item.href}` })),
  { "@type": "ListItem", "position": breadcrumb.length + 2, "name": keyword, "item": pageUrl }
];
const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": fullTitle,
    "description": description,
    "url": pageUrl
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Oteria Conseil",
    "url": siteUrl,
    "description": "Experts en performance énergétique et dispositifs CEE",
    "areaServed": "FR"
  }
];
---

<Base title={title} description={description} canonicalPath={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <!-- HERO SECTION -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-16 md:py-20">
      <!-- Breadcrumb -->
      <nav aria-label="Fil d'Ariane" class="mb-8">
        <ol class="flex items-center gap-2 text-sm" style="color: #9fb3c8;">
          <li><a href="/" class="no-underline transition-colors" style="color: #9fb3c8;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#9fb3c8'">Accueil</a></li>
          {breadcrumb.map((item) => (
            <li class="flex items-center gap-2">
              <span style="color: #627d98;">/</span>
              <a href={item.href} class="no-underline transition-colors" style="color: #9fb3c8;" onmouseover="this.style.color='#ffffff'" onmouseout="this.style.color='#9fb3c8'">{item.label}</a>
            </li>
          ))}
          <li class="flex items-center gap-2">
            <span style="color: #627d98;">/</span>
            <span style="color: #f5c04a;" class="font-medium">{keyword}</span>
          </li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <!-- Left: Title & Description -->
        <div class="lg:col-span-3">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-6" style="color: #ffffff; font-family: var(--font-heading);">
            {title}
          </h1>
          <p class="text-lg leading-relaxed max-w-2xl" style="color: #d9e2ec;">
            {description}
          </p>
          <div class="mt-8 flex items-center gap-6">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div>
              <span class="text-sm" style="color: #9fb3c8;">Diagnostic gratuit</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div>
              <span class="text-sm" style="color: #9fb3c8;">Réponse sous 48h</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div>
              <span class="text-sm" style="color: #9fb3c8;">19 ans d'expertise</span>
            </div>
          </div>
        </div>

        <!-- Right: CTA Card -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-lg p-6 shadow-2xl" id="hero-form">
            <p class="text-base font-bold text-navy-900 mb-1" style="font-family: var(--font-heading)">Diagnostic gratuit</p>
            <p class="text-xs text-navy-600 mb-4">Étude personnalisée sans engagement</p>
            <ul class="space-y-2 mb-5">
              {["Réponse sous 48h ouvrées", "Sans engagement", "19 ans d'expertise en CEE"].map(item => (
                <li class="flex items-center gap-2 text-sm text-navy-700">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="8" r="7" stroke="#48bb78" stroke-width="1.5"/>
                    <path d="M5 8.5l2 2 4-4" stroke="#48bb78" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <a
              href="/diagnostic-gratuit/"
              class="block text-center w-full rounded-md px-4 py-2.5 text-sm font-semibold transition-colors no-underline"
              style="background-color: #d4a024; color: #102a43;"
            >
              Demander un diagnostic →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SOMMAIRE / JOURNEY NAV -->
  {journeyPages.length > 0 && (
    <nav class="expertise-journey" aria-label="Pages de cette expertise">
      <div class="expertise-journey__c">
        <span class="expertise-journey__pre" aria-hidden="true">Dans ce dossier</span>
        <ol class="expertise-journey__track" role="list">
          {journeyPages.map((page) => (
            <li class={`expertise-journey__item${currentPath === page.href ? " is-active" : ""}`}>
              <a
                href={page.href}
                class="expertise-journey__link"
                aria-current={currentPath === page.href ? "page" : undefined}
              >
                {page.label}
              </a>
            </li>
          ))}
        </ol>
      </div>
    </nav>
  )}

  <!-- MAIN CONTENT -->
  <article class="expertise-content">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
      <slot />
    </div>
  </article>

  <!-- RELATED PAGES / SOLUTIONS COMPLÉMENTAIRES -->
  {relatedPages.length > 0 && (
    <section style="border-top:1px solid #d9e2ec; padding:3.5rem 0;">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-8">
          <h2 style="font-family:var(--font-heading); font-size:1.375rem; font-weight:700; color:#102a43; margin:0 0 0.5rem;">Solutions complémentaires</h2>
          <div style="width:2.5rem; height:3px; background:#d4a024; border-radius:9999px;"></div>
        </div>
        <div style={`display:grid; gap:1.25rem; grid-template-columns:repeat(${Math.min(relatedPages.length, 3)}, 1fr);`}>
          {relatedPages.map((page) => (
            <a
              href={page.href}
              style="display:flex; flex-direction:column; background:#ffffff; border:1px solid #d9e2ec; border-top:3px solid #d4a024; border-radius:0.5rem; padding:1.5rem; text-decoration:none; transition:box-shadow 0.2s;"
              onmouseover="this.style.boxShadow='0 4px 16px rgba(16,42,67,0.09)'"
              onmouseout="this.style.boxShadow='none'"
            >
              <h3 style="font-family:var(--font-heading); font-size:1rem; font-weight:700; color:#102a43; margin:0 0 0.5rem;">{page.title}</h3>
              <p style="font-size:0.875rem; color:#486581; line-height:1.6; margin:0 0 1.25rem; flex:1;">{page.description}</p>
              <span style="display:inline-flex; align-items:center; gap:0.375rem; font-size:0.8125rem; font-weight:600; color:#d4a024;">
                Découvrir
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- BOTTOM CTA SECTION -->
  <section class="py-16 md:py-20" style="background-color: #f0f4f8;">
    <div class="mx-auto max-w-7xl px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-4" style="font-family: var(--font-heading)">Optimisez vos coûts avec les CEE</h2>
      <p class="text-navy-600 mb-8 max-w-2xl mx-auto">Nos experts vous accompagnent de l'étude à l'obtention de vos primes. 19 ans d'expérience au service de votre performance énergétique.</p>
      <a href="/diagnostic-gratuit/" class="inline-flex items-center justify-center rounded-md px-8 py-4 text-base font-semibold no-underline transition-colors" style="background-color: #243b53; color: #ffffff;">
        Diagnostic gratuit →
      </a>
    </div>
  </section>


</Base>

<!-- STYLES for content sections -->

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
