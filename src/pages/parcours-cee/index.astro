---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";

const phases = [
  {
    num: "1",
    label: "Diagnostic",
    eyebrow: "Phase 01",
    color: "#f5c04a",
    intro: "Avant tout engagement, nous établissons un état des lieux précis de votre situation énergétique pour ne mobiliser que les dispositifs réellement pertinents.",
    steps: [
      {
        title: "Analyse de votre situation énergétique",
        text: "Étude de votre site, de vos équipements et de vos consommations pour dresser un état des lieux précis.",
      },
      {
        title: "Identification des gisements d'économies",
        text: "Repérage des postes les plus consommateurs et des solutions techniques pertinentes : chauffage, ventilation, process industriels.",
      },
      {
        title: "Identification des aides mobilisables",
        text: "Estimation du montant de prime CEE potentiel selon les fiches d'opérations standardisées applicables à votre projet.",
        link: { href: "/dispositifs/calcul-prime/", label: "Estimer ma prime" },
      },
    ],
  },
  {
    num: "2",
    label: "Accompagnement",
    eyebrow: "Phase 02",
    color: "#d4a024",
    intro: "Oteria Conseil pilote l'ensemble du processus administratif et technique, du montage du dossier jusqu'à la fin des travaux.",
    steps: [
      {
        title: "Montage du dossier & convention CEE",
        text: "Constitution du dossier et signature de la convention CEE avant tout engagement — l'étape qui sécurise votre éligibilité à la prime.",
      },
      {
        title: "Coordination avec les installateurs RGE",
        text: "Mise en relation et coordination avec des installateurs qualifiés RGE, devis conformes aux critères techniques requis par votre fiche d'opération.",
      },
      {
        title: "Suivi des travaux et des obligés CEE",
        text: "Suivi de la réalisation des travaux et des échanges avec l'obligé ou le délégataire jusqu'à validation complète du dossier.",
        link: { href: "/dispositifs/demarches/", label: "Voir le détail des 7 étapes administratives" },
      },
    ],
  },
  {
    num: "3",
    label: "Résultat",
    eyebrow: "Phase 03",
    color: "#102a43",
    intro: "Une fois le dossier validé, votre prime est versée et la performance de vos installations est suivie dans la durée.",
    steps: [
      {
        title: "Dépôt et versement de la prime",
        text: "Dépôt du dossier complet, instruction par le PNCEE puis versement de votre prime CEE, sous 2 à 6 mois après la fin des travaux.",
      },
      {
        title: "Réduction de vos factures",
        text: "Mise en service des équipements installés et baisse de votre consommation énergétique dès leur mise en route.",
      },
      {
        title: "Suivi de la performance dans la durée",
        text: "Oteria Conseil reste à vos côtés pour suivre la performance de vos installations sur le long terme.",
      },
    ],
  },
];
---

<Base
  title="Parcours CEE : les étapes de votre accompagnement"
  description="Du diagnostic énergétique au versement de votre prime CEE : découvrez en détail les étapes de l'accompagnement Oteria Conseil, cabinet de conseil en performance énergétique depuis 19 ans."
  canonicalPath="/parcours-cee/"
>
  <!-- ════════ HERO ════════ -->
  <section class="parcours-hero relative overflow-hidden" style="background-color: #0a1929;">
    <div class="parcours-hero-grid pointer-events-none absolute inset-0"></div>
    <svg class="hero-flow pointer-events-none absolute inset-0 w-full h-full" viewBox="0 0 1200 600" preserveAspectRatio="none" aria-hidden="true">
      <path class="hero-flow__path" d="M-50,420 C200,380 320,180 600,220 C880,260 980,80 1250,140" fill="none" stroke="#f5c04a" stroke-width="1.5" stroke-linecap="round" />
      <path class="hero-flow__path hero-flow__path--2" d="M-50,520 C260,560 380,340 650,380 C920,420 1000,260 1250,300" fill="none" stroke="#486581" stroke-width="1.5" stroke-linecap="round" />
    </svg>

    <div class="relative mx-auto max-w-5xl px-6 pt-24 md:pt-32 pb-16 md:pb-20 text-center">
      <div class="hero-reveal flex items-center justify-center gap-3 mb-6">
        <span class="h-px w-8" style="background-color: #d4a024;"></span>
        <p class="text-sm font-semibold uppercase tracking-widest" style="color: #f8d382;">Notre méthode, en détail</p>
        <span class="h-px w-8" style="background-color: #d4a024;"></span>
      </div>
      <h1 class="hero-reveal text-4xl md:text-6xl font-bold leading-tight" style="color: #ffffff;">
        Le parcours CEE,
        <br />
        <span style="color: #f5c04a;">étape par étape.</span>
      </h1>
      <p class="hero-reveal mt-6 text-base md:text-lg max-w-2xl mx-auto leading-relaxed" style="color: #bcccdc;">
        Du diagnostic initial au versement de votre prime, chaque étape de votre dossier CEE est pilotée par Oteria Conseil. Voici le détail complet du chemin parcouru ensemble.
      </p>
      <div class="hero-reveal mt-10">
        <a href="#parcours" class="inline-flex items-center gap-2 rounded-md px-8 py-3.5 text-base font-semibold no-underline transition-colors" style="background-color: #d4a024; color: #102a43;">
          Découvrir le parcours
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </a>
      </div>

      <!-- Teaser des 3 phases -->
      <div class="hero-reveal hero-teaser mt-16 md:mt-20">
        <svg class="hero-teaser__line" viewBox="0 0 600 2" preserveAspectRatio="none" aria-hidden="true">
          <line x1="0" y1="1" x2="600" y2="1" stroke="#3a5470" stroke-width="1" />
          <line class="hero-teaser__line-fill" x1="0" y1="1" x2="600" y2="1" stroke="#d4a024" stroke-width="1" />
        </svg>
        <div class="hero-teaser__dots">
          {phases.map((phase, i) => (
            <a href={`#phase-${i}`} class="hero-teaser__dot no-underline" style={`animation-delay: ${0.6 + i * 0.15}s`}>
              <span class="hero-teaser__marker" style={`background-color: ${phase.color === "#102a43" ? "#1c3552" : phase.color}; color: ${phase.color === "#f5c04a" ? "#102a43" : "#ffffff"}; border-color: ${phase.color === "#102a43" ? "#f5c04a" : "transparent"};`}>{phase.num}</span>
              <span class="hero-teaser__label">{phase.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bandeau stats -->
    <div class="relative border-t" style="border-color: #1c3552; background-color: #0d1f33;">
      <div class="mx-auto max-w-7xl px-6 py-10 grid grid-cols-2 md:grid-cols-4 gap-8 text-center stats-strip">
        <div class="hero-reveal">
          <p class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-heading); color: #ffffff;"><span class="stat-num" data-target="19">0</span> ans</p>
          <p class="text-xs md:text-sm mt-1" style="color: #829ab1;">D'expertise CEE</p>
        </div>
        <div class="hero-reveal">
          <p class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-heading); color: #ffffff;"><span class="stat-num" data-target="14">0</span>M€</p>
          <p class="text-xs md:text-sm mt-1" style="color: #829ab1;">De primes CEE obtenues</p>
        </div>
        <div class="hero-reveal">
          <p class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-heading); color: #ffffff;"><span class="stat-num" data-target="30">0</span>%</p>
          <p class="text-xs md:text-sm mt-1" style="color: #829ab1;">D'économies moyennes</p>
        </div>
        <div class="hero-reveal">
          <p class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-heading); color: #ffffff;"><span class="stat-num" data-target="48">0</span>h</p>
          <p class="text-xs md:text-sm mt-1" style="color: #829ab1;">Délai de réponse</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ MINI-NAV FLOTTANTE (desktop) ════════ -->
  <nav class="phase-dots hidden lg:flex" aria-label="Navigation des phases du parcours">
    {phases.map((phase, i) => (
      <a href={`#phase-${i}`} class="phase-dot-link no-underline" data-phase-link={i}>
        <span class="phase-dot" data-phase-dot={i}></span>
        <span class="phase-dot-label">{phase.label}</span>
      </a>
    ))}
  </nav>

  <!-- ════════ TIMELINE ════════ -->
  <section id="parcours" class="parcours-timeline relative bg-white py-20 md:py-28">
    <div class="mx-auto max-w-5xl px-6">

      <div class="track-rail hidden md:block" aria-hidden="true">
        <div class="track-rail__fill"></div>
      </div>

      {phases.map((phase, i) => (
        <div class="phase-block relative" id={`phase-${i}`} data-phase-block={i}>

          <!-- En-tête de phase -->
          <div class="phase-header reveal-up relative flex items-center gap-6 mb-12 md:mb-16">
            <div class="phase-ghost-num select-none" aria-hidden="true" style={`color: ${phase.color}`}>{phase.num}</div>
            <div class="relative z-10">
              <p class="text-xs md:text-sm font-semibold uppercase tracking-widest mb-2" style={`color: ${phase.color === "#102a43" ? "#7a530d" : "#7a530d"}`}>{phase.eyebrow}</p>
              <h2 class="text-2xl md:text-4xl font-bold text-navy-900">{phase.label}</h2>
              <p class="mt-3 max-w-xl text-sm md:text-base leading-relaxed text-navy-600">{phase.intro}</p>
            </div>
            <div class="phase-marker hidden md:flex" style={`background-color: ${phase.color}; color: ${phase.color === "#f5c04a" ? "#102a43" : "#ffffff"}`} aria-hidden="true">{phase.num}</div>
          </div>

          <!-- Sous-étapes -->
          <div class="phase-steps grid grid-cols-1 md:grid-cols-3 gap-6 md:pl-[4.5rem]">
            {phase.steps.map((step, j) => (
              <div class="substep-card reveal-up group relative rounded-2xl bg-white border border-navy-100 p-6 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl" style={`transition-delay: ${j * 90}ms; --hover-border: ${phase.color}`}>
                <div class="flex items-center gap-2 mb-4">
                  <span class="substep-index" style={`background-color: ${phase.color}1a; color: ${phase.color === "#f5c04a" ? "#7a530d" : phase.color};`}>{i + 1}.{j + 1}</span>
                </div>
                <h3 class="text-base font-bold text-navy-900 mb-2 leading-snug">{step.title}</h3>
                <p class="text-sm text-navy-600 leading-relaxed">{step.text}</p>
                {step.link && (
                  <a href={step.link.href} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold no-underline" style="color: #7a530d;">
                    {step.link.label}
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                  </a>
                )}
              </div>
            ))}
          </div>

          {i === 2 && (
            <div class="reveal-up mt-10 md:ml-[4.5rem] inline-flex items-start gap-3 rounded-xl border px-5 py-4 max-w-xl" style="background-color: #f6f8f6; border-color: #d1dbd1;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #5a7d5a;" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <p class="text-sm leading-relaxed" style="color: #384f38;"><strong>Aucun frais pour vous</strong> — l'accompagnement Oteria Conseil est entièrement gratuit pour le bénéficiaire.</p>
            </div>
          )}
        </div>
      ))}

    </div>
  </section>

  <!-- ════════ CTA FINAL ════════ -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background-color: #102a43;">
    <div class="parcours-hero-grid pointer-events-none absolute inset-0" style="opacity: 0.5;"></div>
    <div class="relative mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold" style="color: #ffffff;">Votre diagnostic commence ici.</h2>
      <p class="mt-4 text-base md:text-lg" style="color: #d9e2ec;">Échangeons sur votre projet. Réponse sous 48h, sans engagement.</p>
      <div class="mt-10">
        <a href="/diagnostic-gratuit/" class="inline-flex items-center justify-center rounded-md px-10 py-4 text-base font-semibold no-underline transition-colors" style="background-color: #d4a024; color: #102a43;">
          Demander un diagnostic gratuit
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ─── Hero ─── */
  .parcours-hero-grid {
    background-image: radial-gradient(circle, rgba(245, 192, 74, 0.15) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 30%, transparent 100%);
  }

  /* ─── Lignes de flux en fond du hero ─── */
  .hero-flow__path {
    stroke-dasharray: 6 1600;
    stroke-dashoffset: 0;
    opacity: 0.5;
    animation: heroFlowDraw 3.2s ease-out forwards, heroFlowDrift 14s ease-in-out 3.2s infinite alternate;
  }
  .hero-flow__path--2 {
    opacity: 0.35;
    animation-delay: 0.3s, 3.5s;
  }
  @keyframes heroFlowDraw {
    from { stroke-dasharray: 6 1600; stroke-dashoffset: 1600; }
    to { stroke-dasharray: 1600 1600; stroke-dashoffset: 0; }
  }
  @keyframes heroFlowDrift {
    from { transform: translateY(0); }
    to { transform: translateY(-10px); }
  }

  /* ─── Teaser des 3 phases dans le hero ─── */
  .hero-teaser {
    position: relative;
    max-width: 30rem;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-teaser__line {
    display: block;
    width: 100%;
    height: 2px;
    overflow: visible;
  }
  .hero-teaser__line-fill {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: heroLineDraw 1.1s ease-out 0.55s forwards;
  }
  @keyframes heroLineDraw {
    to { stroke-dashoffset: 0; }
  }
  .hero-teaser__dots {
    display: flex;
    justify-content: space-between;
    margin-top: -0.65rem;
  }
  .hero-teaser__dot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translateY(8px) scale(0.85);
    animation: heroDotPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  .hero-teaser__marker {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 999px;
    border: 1.5px solid transparent;
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-heading);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .hero-teaser__dot:hover .hero-teaser__marker {
    transform: scale(1.15);
    box-shadow: 0 0 0 5px rgba(212, 160, 36, 0.18);
  }
  .hero-teaser__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #829ab1;
    transition: color 0.25s ease;
  }
  .hero-teaser__dot:hover .hero-teaser__label {
    color: #f8d382;
  }
  @keyframes heroDotPop {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (max-width: 640px) {
    .hero-teaser__label { font-size: 0.6rem; }
  }

  .hero-reveal {
    opacity: 0;
    transform: translateY(14px);
    animation: heroIn 0.7s ease forwards;
  }
  .hero-reveal:nth-child(1) { animation-delay: 0.05s; }
  .hero-reveal:nth-child(2) { animation-delay: 0.15s; }
  .hero-reveal:nth-child(3) { animation-delay: 0.25s; }
  .hero-reveal:nth-child(4) { animation-delay: 0.35s; }

  @keyframes heroIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── Mini-nav flottante ─── */
  .phase-dots {
    position: fixed;
    right: 1.75rem;
    top: 50%;
    transform: translateY(-50%) translateX(0);
    z-index: 40;
    flex-direction: column;
    align-items: flex-end;
    gap: 0;
    padding: 0.85rem 0.5rem;
    border-radius: 999px;
    background-color: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 20px rgba(16, 42, 67, 0.1);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.35s ease, transform 0.35s ease, visibility 0.35s;
  }

  .phase-dots.is-in-zone {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(-50%) translateX(-4px);
  }

  .phase-dot-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    justify-content: flex-end;
    padding: 0.55rem 0.4rem;
  }

  .phase-dot-link::before {
    content: "";
    position: absolute;
    right: 7.5px;
    top: -50%;
    width: 1.5px;
    height: 100%;
    background-color: #d9e2ec;
    z-index: 0;
  }

  .phase-dot-link:first-child::before {
    top: 50%;
  }

  .phase-dot {
    position: relative;
    z-index: 1;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background-color: #ffffff;
    border: 2px solid #bcccdc;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .phase-dot-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: #829ab1;
    opacity: 0;
    transform: translateX(6px);
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .phase-dot-link:hover .phase-dot-label {
    opacity: 1;
    transform: translateX(0);
  }

  .phase-dot-link:hover .phase-dot {
    border-color: #d4a024;
  }

  .phase-dot-link.is-active .phase-dot {
    background-color: #d4a024;
    border-color: #d4a024;
    transform: scale(1.7);
    box-shadow: 0 0 0 4px rgba(212, 160, 36, 0.18);
  }

  .phase-dot-link.is-active .phase-dot-label {
    opacity: 1;
    transform: translateX(0);
    color: #102a43;
    font-weight: 700;
  }

  /* ─── Rail / timeline ─── */
  .track-rail {
    position: absolute;
    left: calc(4.5rem + 1.5px);
    top: 0;
    bottom: 0;
    width: 3px;
    background-color: #e8ede8;
    border-radius: 999px;
  }

  .track-rail__fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: linear-gradient(180deg, #f5c04a, #d4a024 50%, #102a43);
    border-radius: 999px;
    transition: height 0.1s linear;
  }

  .phase-block {
    padding-bottom: 4rem;
  }
  .phase-block:last-child {
    padding-bottom: 0;
  }

  .phase-ghost-num {
    position: absolute;
    left: -0.5rem;
    top: -2.2rem;
    font-size: 7rem;
    font-weight: 900;
    font-family: var(--font-heading);
    opacity: 0.08;
    line-height: 1;
    z-index: 0;
    pointer-events: none;
  }

  .phase-marker {
    margin-left: auto;
    flex-shrink: 0;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 999px;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    box-shadow: 0 0 0 6px #ffffff, 0 4px 16px rgba(16, 42, 67, 0.18);
    position: relative;
    z-index: 10;
  }

  .substep-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }

  .substep-card {
    box-shadow: 0 1px 2px rgba(16, 42, 67, 0.04);
  }

  .substep-card:hover {
    border-color: var(--hover-border) !important;
  }

  /* ─── Reveal on scroll ─── */
  .reveal-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .reveal-up {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .hero-flow__path,
    .hero-flow__path--2 {
      animation: none;
      opacity: 0.3;
      stroke-dasharray: none;
    }
    .hero-teaser__line-fill {
      animation: none;
      stroke-dashoffset: 0;
    }
    .hero-teaser__dot {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 767px) {
    .phase-ghost-num {
      font-size: 4rem;
      top: -1.4rem;
      left: -0.25rem;
    }
  }
</style>

<script is:inline>
  (function () {
    // Reveal on scroll
    const revealEls = document.querySelectorAll('.reveal-up');
    if ('IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      revealEls.forEach((el) => revealObserver.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add('is-visible'));
    }

    // Timeline rail fill, bound to scroll position within the timeline section
    const timelineSection = document.getElementById('parcours');
    const rail = document.querySelector('.track-rail__fill');
    const phaseDots = document.querySelector('.phase-dots');
    function updateRail() {
      if (!timelineSection || !rail) return;
      const rect = timelineSection.getBoundingClientRect();
      const viewportH = window.innerHeight;
      const total = rect.height;
      const scrolled = Math.min(Math.max(viewportH * 0.5 - rect.top, 0), total);
      const pct = total > 0 ? (scrolled / total) * 100 : 0;
      rail.style.height = pct + '%';

      // Mini-nav visible only while the (light) timeline section is on screen
      if (phaseDots) {
        const inZone = rect.top < viewportH * 0.85 && rect.bottom > viewportH * 0.15;
        phaseDots.classList.toggle('is-in-zone', inZone);
      }
    }
    window.addEventListener('scroll', updateRail, { passive: true });
    window.addEventListener('resize', updateRail);
    updateRail();

    // Mini-nav active phase tracking
    const phaseBlocks = document.querySelectorAll('[data-phase-block]');
    const dotLinks = document.querySelectorAll('[data-phase-link]');
    if ('IntersectionObserver' in window && phaseBlocks.length && dotLinks.length) {
      const navObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const idx = entry.target.getAttribute('data-phase-block');
            const link = document.querySelector(`[data-phase-link="${idx}"]`);
            if (entry.isIntersecting) {
              dotLinks.forEach((l) => l.classList.remove('is-active'));
              link?.classList.add('is-active');
            }
          });
        },
        { rootMargin: '-45% 0px -45% 0px' }
      );
      phaseBlocks.forEach((b) => navObserver.observe(b));
    }

    // Compteurs animés des statistiques du hero
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const statNums = document.querySelectorAll('.stat-num');
    function animateStat(el) {
      const target = parseInt(el.getAttribute('data-target'), 10) || 0;
      if (reduceMotion) {
        el.textContent = target;
        return;
      }
      const duration = 1200;
      const start = performance.now();
      function tick(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(target * eased);
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = target;
      }
      requestAnimationFrame(tick);
    }
    const statsStrip = document.querySelector('.stats-strip');
    if (statsStrip && 'IntersectionObserver' in window) {
      const statsObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              statNums.forEach(animateStat);
              statsObserver.disconnect();
            }
          });
        },
        { threshold: 0.3 }
      );
      statsObserver.observe(statsStrip);
    } else {
      statNums.forEach(animateStat);
    }
  })();
</script>
