---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";
---

<Base
  title="Contact installateurs – Oteria Conseil"
  description="Vous êtes installateur ou partenaire technique ? Contactez Oteria Conseil pour vos dossiers CEE et montages de primes."
  canonicalPath="/contact-installateur/"
>
  <!-- Compact hero -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-12 md:py-16 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #f5c04a;">Espace installateurs</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight max-w-3xl mx-auto" style="color: #ffffff; font-family: var(--font-heading);">Vous êtes installateur ou partenaire technique ?</h1>
      <p class="mt-4 text-lg leading-relaxed max-w-2xl mx-auto" style="color: #d9e2ec;">Contactez-nous pour le montage de vos dossiers CEE et le suivi de vos chantiers.</p>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-12 md:py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">

        <!-- Right column: Contact form -->
        <div class="lg:col-span-5 order-first lg:order-last">
          <div class="lg:sticky lg:top-24">
            <div class="bg-white rounded-lg p-8 md:p-10 border shadow-lg" style="border-color: #d9e2ec; box-shadow: 0 10px 40px -10px rgba(16, 42, 67, 0.12);">
              <h2 class="text-xl font-bold mb-1" style="color: #102a43; font-family: var(--font-heading);">Contacter notre équipe</h2>
              <p class="text-sm mb-8" style="color: #486581;">Réponse sous 48h ouvrées</p>

              <form action="/contact-installateur/" method="GET" class="space-y-5">
                <div>
                  <label for="raison_sociale" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Raison sociale</label>
                  <input
                    type="text"
                    id="raison_sociale"
                    name="raison_sociale"
                    required
                    placeholder="Nom de votre entreprise"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="nom" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Nom</label>
                  <input
                    type="text"
                    id="nom"
                    name="nom"
                    required
                    placeholder="Votre nom"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="email" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Email professionnel</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="vous@entreprise.fr"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="telephone" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Téléphone</label>
                  <input
                    type="tel"
                    id="telephone"
                    name="telephone"
                    required
                    placeholder="01 23 45 67 89"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="message" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Message</label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="4"
                    placeholder="Type de chantier, référence du dossier CEE, urgence"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors resize-none"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full rounded-md px-6 py-4 text-base font-semibold transition-colors cursor-pointer border-none"
                  style="background-color: #d4a024; color: #102a43;"
                >
                  Envoyer ma demande
                </button>
              </form>

              <p class="mt-5 text-xs text-center leading-relaxed" style="color: #486581;">
                <svg class="inline-block w-3.5 h-3.5 mr-1 align-text-bottom" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="color: #486581;"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
                Vos données sont protégées. <a href="/politique-confidentialite/" class="underline" style="color: #486581;">Politique de confidentialité</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Left column: Content -->
        <div class="lg:col-span-7 order-last lg:order-first">
          <div class="flex flex-wrap gap-x-6 gap-y-3 mb-10">
            <span class="flex items-center gap-2 text-sm font-medium" style="color: #334e68;">
              <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs" style="background-color: #f0f4f8; color: #276749;">&#10003;</span>
              Réponse sous 48h
            </span>
            <span class="flex items-center gap-2 text-sm font-medium" style="color: #334e68;">
              <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs" style="background-color: #f0f4f8; color: #276749;">&#10003;</span>
              Interlocuteur dédié
            </span>
            <span class="flex items-center gap-2 text-sm font-medium" style="color: #334e68;">
              <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs" style="background-color: #f0f4f8; color: #276749;">&#10003;</span>
              19 ans d'expertise CEE
            </span>
          </div>

          <div>
            <h2 class="text-xl md:text-2xl font-bold mb-6" style="color: #102a43; font-family: var(--font-heading);">Pourquoi nous contacter ?</h2>
            <p class="text-sm leading-relaxed mb-4" style="color: #486581;">
              Vous intervenez sur un chantier éligible aux Certificats d'Économies d'Énergie et souhaitez monter ou suivre un dossier CEE avec Oteria Conseil ? Notre équipe accompagne les installateurs et partenaires techniques sur le montage administratif, le calcul des primes et le suivi des bénéficiaires.
            </p>
            <p class="text-sm leading-relaxed" style="color: #486581;">
              Remplissez le formulaire ci-contre avec les informations de votre chantier : un consultant dédié vous recontacte sous 48h ouvrées.
            </p>
          </div>

          <!-- Trust arguments -->
          <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="rounded-lg p-5 border" style="border-color: #d9e2ec; background-color: #f0f4f8;">
              <div class="w-10 h-10 rounded-md flex items-center justify-center mb-3" style="background-color: #ffffff; border: 1px solid #d9e2ec;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#243b53"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              </div>
              <h3 class="text-sm font-bold mb-1.5" style="color: #102a43;">Dossiers vérifiés avant dépôt</h3>
              <p class="text-sm leading-relaxed" style="color: #486581;">Chaque pièce justificative est contrôlée au regard de la fiche d'opération standardisée applicable, pour limiter le risque de refus ou de demande de complément par le PNCEE.</p>
            </div>

            <div class="rounded-lg p-5 border" style="border-color: #d9e2ec; background-color: #f0f4f8;">
              <div class="w-10 h-10 rounded-md flex items-center justify-center mb-3" style="background-color: #ffffff; border: 1px solid #d9e2ec;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#243b53"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
              </div>
              <h3 class="text-sm font-bold mb-1.5" style="color: #102a43;">Fiches CEE à jour</h3>
              <p class="text-sm leading-relaxed" style="color: #486581;">Veille réglementaire continue sur les versions de fiches, les forfaits de kWh cumac et les critères techniques d'éligibilité, pour sécuriser chaque calcul de prime.</p>
            </div>

            <div class="rounded-lg p-5 border" style="border-color: #d9e2ec; background-color: #f0f4f8;">
              <div class="w-10 h-10 rounded-md flex items-center justify-center mb-3" style="background-color: #ffffff; border: 1px solid #d9e2ec;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#243b53"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg>
              </div>
              <h3 class="text-sm font-bold mb-1.5" style="color: #102a43;">Suivi de bout en bout</h3>
              <p class="text-sm leading-relaxed" style="color: #486581;">Du dépôt du dossier à la validation du bénéficiaire, vous êtes tenu informé de l'avancement à chaque étape par votre interlocuteur dédié.</p>
            </div>

            <div class="rounded-lg p-5 border" style="border-color: #d9e2ec; background-color: #f0f4f8;">
              <div class="w-10 h-10 rounded-md flex items-center justify-center mb-3" style="background-color: #ffffff; border: 1px solid #d9e2ec;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#243b53"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              </div>
              <h3 class="text-sm font-bold mb-1.5" style="color: #102a43;">Réactivité garantie</h3>
              <p class="text-sm leading-relaxed" style="color: #486581;">Un consultant dédié vous répond sous 48h ouvrées, avec une expertise CEE construite depuis 19 ans auprès des installateurs et partenaires techniques.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Related pages -->
  <section class="py-10 border-t" style="background-color: #f0f4f8; border-color: #d9e2ec;">
    <div class="mx-auto max-w-7xl px-6">
      <p class="text-sm mb-4" style="color: #486581;">Découvrir nos services :</p>
      <div class="flex flex-wrap gap-4">
        <a href="/dispositifs/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Dispositifs CEE</a>
        <a href="/expertises/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Nos expertises</a>
        <a href="/diagnostic-gratuit/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Diagnostic gratuit (bénéficiaires)</a>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
