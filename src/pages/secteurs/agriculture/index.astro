---
import "../../../styles/global.css";
import Base from "../../../layouts/Base.astro";
---

<Base
  title="Performance énergétique agriculture : solutions et aides CEE"
  description="Solutions d'efficacité énergétique pour l'agriculture : serres, séchage, irrigation, bâtiments d'élevage. Fiches CEE AGRI-*, cumul avec le Plan de compétitivité."
  canonicalPath="/secteurs/agriculture/"
>
  <!-- Breadcrumb -->
  <nav class="bg-white border-b border-navy-100" aria-label="Fil d'Ariane">
    <div class="mx-auto max-w-7xl px-6 py-3">
      <ol class="flex items-center gap-2 text-sm text-navy-600">
        <li><a href="/" class="hover:text-gold-600 no-underline">Accueil</a></li>
        <li class="before:content-['/'] before:mx-2"><a href="/secteurs/" class="hover:text-gold-600 no-underline">Secteurs</a></li>
        <li class="before:content-['/'] before:mx-2 text-navy-900 font-medium">Agriculture</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: #f5c04a;">Marché agriculture</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight max-w-4xl" style="color: #ffffff;">Performance énergétique agriculture : solutions et aides CEE</h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl" style="color: #d9e2ec;">Les exploitations agricoles consomment de l'énergie pour chauffer, sécher, irriguer et ventiler. Les CEE financent la modernisation de vos équipements.</p>
    </div>
  </section>

  <!-- Article -->
  <article class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-3xl px-6">

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Les défis énergétiques du monde agricole</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        L'agriculture française consomme environ 4,5 Mtep (millions de tonnes équivalent pétrole) d'énergie directe par an, hors carburants de traction. Les postes de consommation sont très spécifiques au secteur : chauffage de serres, séchage de céréales et fourrages, ventilation et chauffage des bâtiments d'élevage, irrigation, tank à lait, chambres froides.
      </p>

      <p class="text-navy-700 mb-4 leading-relaxed">
        La hausse des coûts de l'énergie impacte directement les charges d'exploitation et la compétitivité des filières agricoles françaises. Pour les serristes, l'énergie représente jusqu'à 30 % du coût de production. Pour les éleveurs, le chauffage des bâtiments d'élevage (porcheries, poulaillers) et le refroidissement du lait constituent des postes lourds.
      </p>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Le dispositif <a href="/dispositifs/comprendre-les-cee/" class="text-gold-700 underline hover:text-gold-800">CEE</a> propose des fiches spécifiques au secteur agricole (AGRI-*) qui permettent de financer la modernisation des équipements énergivores. Combinés aux aides du Plan de compétitivité et aux subventions FranceAgriMer, les CEE constituent un levier financier puissant pour les exploitants.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Les opérations CEE pour l'agriculture (fiches AGRI-*)</h2>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Serres et horticulture</h3>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>AGRI-TH-101</strong> : Chaudière biomasse en remplacement d'une chaudière fioul/gaz pour le chauffage de serres</li>
        <li><strong>AGRI-TH-104</strong> : Écran thermique dans les serres — réduction des déperditions nocturnes de 30 à 50 %</li>
        <li><strong>AGRI-TH-108</strong> : Pompe à chaleur pour le chauffage de serres</li>
        <li><strong>AGRI-TH-109</strong> : Régulation climatique des serres (sondes, automates, gestion par zone)</li>
        <li><strong>AGRI-EN-101</strong> : Couverture de serre performante (double paroi, matériaux à faible émissivité)</li>
      </ul>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Séchage et stockage</h3>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>AGRI-TH-103</strong> : Récupération de chaleur sur séchoir — valorisation de la chaleur fatale pour le préchauffage de l'air</li>
        <li><strong>AGRI-TH-105</strong> : Séchoir biomasse en remplacement d'un séchoir à combustible fossile</li>
        <li><strong>AGRI-UT-104</strong> : Variateur de vitesse sur ventilateurs de séchoir</li>
        <li><strong>AGRI-EQ-101</strong> : Pré-refroidisseur sur tank à lait — réduction de la consommation du groupe froid de 40 à 60 %</li>
      </ul>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Bâtiments d'élevage</h3>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>AGRI-TH-106</strong> : Isolation des bâtiments d'élevage (porcheries, poulaillers)</li>
        <li><strong>AGRI-TH-107</strong> : Échangeur air-air sur bâtiment d'élevage — récupération de chaleur sur l'air extrait tout en renouvelant l'air intérieur</li>
        <li><strong>AGRI-UT-102</strong> : Éclairage LED des bâtiments agricoles</li>
        <li><strong>AGRI-UT-103</strong> : Chauffage infrarouge localisé (radiant) pour les porcelets et volailles</li>
      </ul>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Irrigation et pompage</h3>

      <ul class="list-disc pl-6 text-navy-700 mb-8 space-y-2">
        <li><strong>AGRI-UT-101</strong> : Système de régulation sur un réseau d'irrigation — pilotage par sondes tensiométriques ou stations météo</li>
        <li><strong>AGRI-UT-104</strong> : Variateur de vitesse sur pompe d'irrigation — adaptation du débit aux besoins réels</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Le cumul des aides en agriculture</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les exploitants agricoles bénéficient de plusieurs dispositifs d'aide cumulables avec les CEE :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>Plan de compétitivité et d'adaptation des exploitations agricoles (PCAE)</strong> : subvention de 20 à 40 % portée par les Régions et cofinancée par le FEADER</li>
        <li><strong>FranceAgriMer</strong> : aides spécifiques par filière (aide à l'investissement en serres, stockage, etc.)</li>
        <li><strong>CEE</strong> : cumulables avec le PCAE et les aides FranceAgriMer, sans plafond de cumul spécifique</li>
        <li><strong>Prêt vert agricole</strong> : financement bonificé pour les investissements de transition énergétique</li>
        <li><strong>Crédit d'impôt glyphosate / HVE</strong> : dans le cadre d'une démarche globale de transition</li>
      </ul>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Le cumul de ces dispositifs peut réduire le reste à charge de l'exploitant à 20-30 % de l'investissement total. Oteria Conseil coordonne l'ensemble des demandes d'aides pour garantir un plan de financement optimal et le respect des plafonds de cumul.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">L'audit énergétique agricole</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        L'audit énergétique est la première étape d'une démarche d'efficacité sur une exploitation. Il permet de :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li>Dresser le bilan complet des consommations par poste (chauffage, électricité spécifique, carburants)</li>
        <li>Identifier les gisements d'économies prioritaires et les investissements les plus rentables</li>
        <li>Calculer les volumes de <a href="/dispositifs/kwh-cumac/" class="text-gold-700 underline hover:text-gold-800">kWh cumac</a> mobilisables par opération</li>
        <li>Établir un plan de travaux pluriannuel avec priorisation par ROI</li>
        <li>Constituer la base technique pour les dossiers d'opérations spécifiques (projets atypiques)</li>
      </ul>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Le coût de l'audit est souvent partiellement pris en charge par le PCAE ou les programmes CEE d'accompagnement. Oteria Conseil peut vous orienter vers les dispositifs de financement de la phase d'étude.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Investissements typiques et retour sur investissement</h2>

      <div class="overflow-x-auto mb-8">
        <table class="w-full border-collapse text-sm text-navy-700">
          <thead>
            <tr class="bg-navy-50">
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Opération</th>
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Investissement type</th>
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">ROI avec aides</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border border-navy-200 px-4 py-3">Écran thermique de serre (1 ha)</td>
              <td class="border border-navy-200 px-4 py-3">40 000 - 60 000 €</td>
              <td class="border border-navy-200 px-4 py-3">2-3 ans</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">PAC pour serre</td>
              <td class="border border-navy-200 px-4 py-3">80 000 - 150 000 €</td>
              <td class="border border-navy-200 px-4 py-3">4-6 ans</td>
            </tr>
            <tr>
              <td class="border border-navy-200 px-4 py-3">Échangeur air/air élevage</td>
              <td class="border border-navy-200 px-4 py-3">15 000 - 30 000 €</td>
              <td class="border border-navy-200 px-4 py-3">2-4 ans</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">Pré-refroidisseur tank à lait</td>
              <td class="border border-navy-200 px-4 py-3">3 000 - 8 000 €</td>
              <td class="border border-navy-200 px-4 py-3">1-2 ans</td>
            </tr>
            <tr>
              <td class="border border-navy-200 px-4 py-3">Variateurs sur irrigation</td>
              <td class="border border-navy-200 px-4 py-3">5 000 - 15 000 €</td>
              <td class="border border-navy-200 px-4 py-3">2-3 ans</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">LED bâtiments (500 m²)</td>
              <td class="border border-navy-200 px-4 py-3">8 000 - 15 000 €</td>
              <td class="border border-navy-200 px-4 py-3">1-3 ans</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">L'accompagnement Oteria Conseil pour les agriculteurs</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Nous comprenons les spécificités du monde agricole : saisonnalité des travaux, disponibilité limitée des exploitants, nécessité de maintenir la production pendant les interventions. Notre accompagnement est adapté :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-8 space-y-2">
        <li><strong>Diagnostic terrain</strong> : visite de l'exploitation, analyse des factures et des process, identification des gisements</li>
        <li><strong>Montage financier complet</strong> : CEE + PCAE + FranceAgriMer + aides locales, un seul interlocuteur pour toutes les démarches</li>
        <li><strong>Coordination avec les fournisseurs</strong> : interface avec les installateurs spécialisés en agriculture (chauffagistes serres, électriciens agricoles)</li>
        <li><strong>Gestion administrative</strong> : nous gérons l'intégralité du dossier CEE, vous vous concentrez sur votre exploitation</li>
        <li><strong>Calendrier adapté</strong> : planification des travaux en fonction des cycles culturaux et d'élevage</li>
      </ul>

      <!-- CTA -->
      <div class="rounded-lg p-8 mt-12 text-center" style="background-color: #f0f4f8;">
        <h3 class="text-xl font-bold text-navy-900 mb-3">Exploitants, coopératives : réduisez vos charges énergétiques</h3>
        <p class="text-navy-600 mb-6">Diagnostic gratuit de votre exploitation et estimation des aides mobilisables sous 48h.</p>
        <a href="/diagnostic-gratuit/" class="inline-flex items-center justify-center rounded-md px-8 py-4 text-base font-semibold no-underline transition-colors" style="background-color: #d4a024; color: #102a43;">
          Demander un diagnostic agricole
        </a>
      </div>
    </div>
  </article>

  <!-- Liens connexes -->
  <section class="py-12 border-t border-navy-100" style="background-color: #f0f4f8;">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-xl font-bold text-navy-900 mb-6">Ressources utiles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/dispositifs/comprendre-les-cee/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Comprendre les CEE</p>
          <p class="text-xs text-navy-600 mt-1">Le dispositif expliqué</p>
        </a>
        <a href="/dispositifs/calcul-prime/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Calcul de prime</p>
          <p class="text-xs text-navy-600 mt-1">Estimez votre aide</p>
        </a>
        <a href="/dispositifs/demarches/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Démarches CEE</p>
          <p class="text-xs text-navy-600 mt-1">Étapes pour obtenir la prime</p>
        </a>
        <a href="/secteurs/industrie/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Industrie</p>
          <p class="text-xs text-navy-600 mt-1">Solutions industrielles</p>
        </a>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
