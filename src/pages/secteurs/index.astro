---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";
---

<Base
  title="Performance énergétique par secteur d'activité"
  description="Oteria Conseil accompagne tous les secteurs professionnels dans leur performance énergétique : industrie, tertiaire, collectivités, agriculture, habitat collectif, logistique."
  canonicalPath="/secteurs/"
>
  <!-- Breadcrumb -->
  <nav class="bg-white border-b border-navy-100" aria-label="Fil d'Ariane">
    <div class="mx-auto max-w-7xl px-6 py-3">
      <ol class="flex items-center gap-2 text-sm text-navy-600">
        <li><a href="/" class="hover:text-gold-600 no-underline">Accueil</a></li>
        <li class="before:content-['/'] before:mx-2 text-navy-900 font-medium">Secteurs</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: #f5c04a;">Nos marchés</p>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight" style="color: #ffffff;">Performance énergétique par secteur d'activité</h1>
          <p class="mt-6 text-lg leading-relaxed" style="color: #d9e2ec;">Chaque secteur a ses enjeux énergétiques propres. Oteria Conseil adapte son accompagnement aux spécificités de votre activité pour maximiser vos économies et vos aides.</p>
          <div class="mt-8 flex items-center gap-6">
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div><span class="text-sm" style="color: #9fb3c8;">Diagnostic gratuit</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div><span class="text-sm" style="color: #9fb3c8;">Réponse sous 48h</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div><span class="text-sm" style="color: #9fb3c8;">19 ans d'expertise</span></div>
          </div>
        </div>
        <div class="lg:col-span-2">
          <div class="bg-white rounded-lg p-6 shadow-2xl hero-form">
            <p class="text-base font-bold text-navy-900 mb-1" style="font-family: var(--font-heading)">Diagnostic gratuit</p>
            <p class="text-xs text-navy-600 mb-4">Étude personnalisée sans engagement</p>
            <ul class="space-y-2 mb-5">
              {["Réponse sous 48h", "Sans engagement", "19 ans d'expertise"].map(item => (
                <li class="flex items-center gap-2 text-sm text-navy-700">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="8" r="7" stroke="#48bb78" stroke-width="1.5"/>
                    <path d="M5 8.5l2 2 4-4" stroke="#48bb78" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href="/diagnostic-gratuit/" class="block text-center w-full rounded-md px-4 py-2.5 text-sm font-semibold no-underline" style="background-color: #d4a024; color: #102a43;">Demander un diagnostic →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="py-16 md:py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="max-w-3xl">
        <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Une expertise multi-sectorielle éprouvée</h2>
        <p class="text-navy-700 mb-4 leading-relaxed">
          Forts d'une expérience sectorielle de 19 ans, nos experts accompagnent des professionnels de tous secteurs dans l'optimisation de leur performance énergétique. Notre connaissance approfondie des <a href="/dispositifs/comprendre-les-cee/" class="text-gold-700 underline hover:text-gold-800">certificats d'économie d'énergie</a>, combinée à une expertise technique sectorielle, nous permet d'identifier les leviers les plus pertinents pour chaque type d'activité.
        </p>
        <p class="text-navy-700 leading-relaxed">
          Que vous soyez industriel, gestionnaire de bâtiments tertiaires, élu local, bailleur social ou exploitant agricole, nous parlons votre langage et connaissons vos contraintes. Découvrez ci-dessous notre approche par secteur.
        </p>
      </div>
    </div>
  </section>

  <!-- Grille des secteurs -->
  <section class="py-16 md:py-24" style="background-color: #f0f4f8;">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Industrie -->
        <a href="/secteurs/industrie/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-gold-700">Industrie</h3>
          <p class="text-sm text-navy-600 leading-relaxed mb-4">Process thermiques, air comprimé, moteurs et variateurs. Optimisez vos utilités industrielles et valorisez vos investissements via les CEE.</p>
          <span class="text-sm font-semibold text-gold-700">Découvrir nos solutions &rarr;</span>
        </a>

        <!-- Tertiaire -->
        <a href="/secteurs/tertiaire/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-gold-700">Tertiaire</h3>
          <p class="text-sm text-navy-600 leading-relaxed mb-4">Bureaux, commerces, santé, enseignement. Décret tertiaire, BACS et solutions CEE pour vos bâtiments professionnels.</p>
          <span class="text-sm font-semibold text-gold-700">Découvrir nos solutions &rarr;</span>
        </a>

        <!-- Collectivités -->
        <a href="/secteurs/collectivites/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-gold-700">Collectivités</h3>
          <p class="text-sm text-navy-600 leading-relaxed mb-4">Patrimoine public, éclairage, piscines, écoles. Cumul CEE + Fonds vert + DSIL pour vos projets de rénovation énergétique.</p>
          <span class="text-sm font-semibold text-gold-700">Découvrir nos solutions &rarr;</span>
        </a>

        <!-- Habitat collectif -->
        <a href="/secteurs/habitat-collectif/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-gold-700">Habitat collectif</h3>
          <p class="text-sm text-navy-600 leading-relaxed mb-4">Copropriétés et bailleurs sociaux. DPE collectif, plan de travaux et cumul CEE + MaPrimeRénov' Copro.</p>
          <span class="text-sm font-semibold text-gold-700">Découvrir nos solutions &rarr;</span>
        </a>

        <!-- Agriculture -->
        <a href="/secteurs/agriculture/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-gold-700">Agriculture</h3>
          <p class="text-sm text-navy-600 leading-relaxed mb-4">Serres, séchage, irrigation, élevage. Fiches AGRI-* et cumul avec les aides à la compétitivité agricole.</p>
          <span class="text-sm font-semibold text-gold-700">Découvrir nos solutions &rarr;</span>
        </a>

        <!-- Logistique -->
        <a href="/secteurs/logistique/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.079-.481 1.09-1.101.004-.228.013-.453.026-.673M2.25 14.25V6.375c0-.621.504-1.125 1.125-1.125h10.5c.621 0 1.125.504 1.125 1.125v.75m2.25 9h1.088c.158-.412.357-.803.593-1.168a6.008 6.008 0 0 1 2.392-2.227l.215-.114a6.036 6.036 0 0 0 2.192-1.994c.312-.501.484-1.078.484-1.672 0-1.38-1.044-2.547-2.41-2.7a6.01 6.01 0 0 0-6.49 4.655M15 5.25v7.5" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-gold-700">Logistique</h3>
          <p class="text-sm text-navy-600 leading-relaxed mb-4">Entrepôts, plateformes frigorifiques, éclairage 24/7. Solutions CEE pour les grands volumes et la chaîne du froid.</p>
          <span class="text-sm font-semibold text-gold-700">Découvrir nos solutions &rarr;</span>
        </a>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 border-t border-navy-100 bg-white">
    <div class="mx-auto max-w-7xl px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-4">Votre secteur n'est pas listé ?</h2>
      <p class="text-navy-600 mb-8 max-w-2xl mx-auto">Notre expertise CEE couvre l'ensemble des secteurs économiques. Contactez-nous pour un diagnostic adapté à votre activité.</p>
      <a href="/diagnostic-gratuit/" class="inline-flex items-center justify-center rounded-md px-8 py-4 text-base font-semibold no-underline transition-colors" style="background-color: #d4a024; color: #102a43;">
        Demander un diagnostic gratuit
      </a>
    </div>
  </section>
</Base>

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
