---
import "../../../styles/global.css";
import Base from "../../../layouts/Base.astro";
---

<Base
  title="Performance énergétique collectivités : solutions et financements"
  description="Solutions d'efficacité énergétique pour les collectivités : patrimoine public, éclairage, piscines, écoles. Cumul CEE + Fonds vert + DSIL + DETR. Contrats de performance."
  canonicalPath="/secteurs/collectivites/"
>
  <!-- Breadcrumb -->
  <nav class="bg-white border-b border-navy-100" aria-label="Fil d'Ariane">
    <div class="mx-auto max-w-7xl px-6 py-3">
      <ol class="flex items-center gap-2 text-sm text-navy-600">
        <li><a href="/" class="hover:text-gold-600 no-underline">Accueil</a></li>
        <li class="before:content-['/'] before:mx-2"><a href="/secteurs/" class="hover:text-gold-600 no-underline">Secteurs</a></li>
        <li class="before:content-['/'] before:mx-2 text-navy-900 font-medium">Collectivités</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: #f5c04a;">Marché collectivités</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight max-w-4xl" style="color: #ffffff;">Performance énergétique collectivités : solutions et financements</h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl" style="color: #d9e2ec;">Les collectivités territoriales gèrent un patrimoine immobilier vaste et énergivore. Les CEE, combinés aux aides publiques, financent la transition énergétique de vos bâtiments.</p>
    </div>
  </section>

  <!-- Article -->
  <article class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-3xl px-6">

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Les enjeux énergétiques des collectivités</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les collectivités territoriales françaises possèdent un patrimoine immobilier considérable : écoles, crèches, gymnases, piscines, mairies, bibliothèques, salles polyvalentes, EHPAD, logements sociaux. Ce parc, souvent construit entre les années 1960 et 1990, est majoritairement énergivore : 70 % des bâtiments publics ont un DPE classé D ou inférieur.
      </p>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Face à la hausse des prix de l'énergie (certaines communes ont vu leur facture énergétique doubler entre 2021 et 2023), la rénovation du patrimoine public devient un impératif budgétaire autant qu'environnemental. Mais les contraintes sont fortes : budgets limités, continuité de service, marchés publics, dette maîtrisée.
      </p>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Le dispositif <a href="/dispositifs/comprendre-les-cee/" class="text-gold-700 underline hover:text-gold-800">CEE</a>, combiné aux multiples aides publiques disponibles, permet aux collectivités de financer jusqu'à 80-90 % de leurs investissements en rénovation énergétique, rendant ces projets accessibles même avec des budgets contraints.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Le cumul des financements pour les collectivités</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les collectivités bénéficient d'un cumul d'aides particulièrement favorable :
      </p>

      <div class="overflow-x-auto mb-8">
        <table class="w-full border-collapse text-sm text-navy-700">
          <thead>
            <tr class="bg-navy-50">
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Dispositif</th>
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Taux d'aide</th>
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Cumulable CEE</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border border-navy-200 px-4 py-3">CEE (<a href="/dispositifs/obliges/" class="text-gold-700 underline hover:text-gold-800">obligés</a>)</td>
              <td class="border border-navy-200 px-4 py-3">10-30 % du coût</td>
              <td class="border border-navy-200 px-4 py-3">—</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">Fonds vert</td>
              <td class="border border-navy-200 px-4 py-3">Jusqu'à 80 %</td>
              <td class="border border-navy-200 px-4 py-3">Oui</td>
            </tr>
            <tr>
              <td class="border border-navy-200 px-4 py-3">DSIL (Dotation de Soutien à l'Investissement Local)</td>
              <td class="border border-navy-200 px-4 py-3">20-80 %</td>
              <td class="border border-navy-200 px-4 py-3">Oui</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">DETR (Dotation d'Équipement des Territoires Ruraux)</td>
              <td class="border border-navy-200 px-4 py-3">20-80 %</td>
              <td class="border border-navy-200 px-4 py-3">Oui</td>
            </tr>
            <tr>
              <td class="border border-navy-200 px-4 py-3">Fonds Chaleur (ADEME)</td>
              <td class="border border-navy-200 px-4 py-3">40-65 %</td>
              <td class="border border-navy-200 px-4 py-3">Oui (plafond global)</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">Aides régionales / départementales</td>
              <td class="border border-navy-200 px-4 py-3">Variable</td>
              <td class="border border-navy-200 px-4 py-3">Oui</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Le cumul de ces aides peut réduire le reste à charge de la collectivité à 10-20 % du coût total de l'opération. Oteria Conseil optimise l'ingénierie financière en articulant les CEE avec les autres dispositifs disponibles, en respectant les plafonds de cumul.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Les bâtiments publics à fort potentiel</h2>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Écoles et groupes scolaires</h3>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les écoles représentent souvent 40 à 60 % de la facture énergétique d'une commune. Construites majoritairement avant 1975, elles cumulent isolation déficiente, chauffage surdimensionné et régulation absente. Les opérations CEE prioritaires : isolation de toiture (forte surface, fort gain), remplacement de chaudière par PAC, installation de robinets thermostatiques, LED en éclairage intérieur et extérieur.
      </p>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Piscines et équipements sportifs</h3>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les piscines municipales sont des gouffres énergétiques : chauffage de l'eau, déshumidification, traitement de l'air, éclairage. Un programme de travaux combinant PAC sur eau de bassin, <a href="/expertises/vmc-double-flux/" class="text-gold-700 underline hover:text-gold-800">VMC double flux</a> avec récupération sur air extrait, couverture de bassin et LED peut réduire la facture de 40 à 60 %.
      </p>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Éclairage public</h3>

      <p class="text-navy-700 mb-4 leading-relaxed">
        L'éclairage public représente 30 à 40 % de la consommation d'électricité des communes. Le passage en LED avec système de gradation et horloge astronomique génère des économies de 50 à 70 % et des volumes de CEE significatifs. La fiche RES-EC-104 (éclairage public) offre des forfaits attractifs.
      </p>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Mairies, salles polyvalentes, EHPAD</h3>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Ces bâtiments bénéficient des mêmes fiches CEE que le tertiaire privé : isolation, PAC, GTB, VMC double flux, LED. La particularité des collectivités est la possibilité de regrouper plusieurs bâtiments dans un même programme de travaux pluriannuel, maximisant les volumes de CEE et simplifiant la gestion administrative.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Le Contrat de Performance Énergétique (CPE)</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Le CPE est un outil contractuel particulièrement adapté aux collectivités. Il engage un opérateur privé à réaliser des travaux et à garantir un niveau d'économies d'énergie sur une durée de 8 à 20 ans. Si les économies ne sont pas atteintes, l'opérateur compense financièrement la collectivité.
      </p>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Le CPE présente plusieurs avantages pour les collectivités :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>Garantie de résultat</strong> : les économies sont contractuellement garanties</li>
        <li><strong>Financement par les économies</strong> : les travaux se remboursent par la réduction de la facture énergétique</li>
        <li><strong>Expertise technique</strong> : l'opérateur assure la conception, la réalisation et la maintenance</li>
        <li><strong>Compatibilité CEE</strong> : les CEE générés sont intégrés au schéma de financement du CPE</li>
      </ul>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Oteria Conseil accompagne les collectivités dans la structuration de leurs CPE : rédaction du programme fonctionnel, assistance à la passation du marché, vérification des garanties et intégration des CEE dans le plan de financement.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Notre accompagnement des collectivités</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Oteria Conseil comprend les spécificités de la commande publique et adapte son intervention :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-8 space-y-2">
        <li><strong>Diagnostic patrimonial</strong> : analyse de l'ensemble du parc immobilier, priorisation des interventions par ratio coût/économie</li>
        <li><strong>Plan pluriannuel d'investissement (PPI)</strong> : séquencement des travaux compatible avec les contraintes budgétaires et les calendriers électoraux</li>
        <li><strong>Ingénierie financière</strong> : articulation CEE + Fonds vert + DSIL + DETR + Fonds Chaleur pour minimiser le reste à charge</li>
        <li><strong>Assistance à maîtrise d'ouvrage</strong> : accompagnement dans la passation des marchés de travaux et le suivi d'exécution</li>
        <li><strong>Conformité juridique</strong> : respect du code de la commande publique, chronologie CEE adaptée aux procédures de marchés</li>
        <li><strong>Obligation d'exemplarité</strong> : valorisation des actions dans le cadre du décret tertiaire applicable aux bâtiments publics > 1 000 m²</li>
      </ul>

      <!-- CTA -->
      <div class="rounded-lg p-8 mt-12 text-center" style="background-color: #f0f4f8;">
        <h3 class="text-xl font-bold text-navy-900 mb-3">Élus, DGS, directeurs techniques : parlons de votre patrimoine</h3>
        <p class="text-navy-600 mb-6">Diagnostic gratuit de votre parc immobilier et simulation des financements mobilisables.</p>
        <a href="/diagnostic-gratuit/" class="inline-flex items-center justify-center rounded-md px-8 py-4 text-base font-semibold no-underline transition-colors" style="background-color: #d4a024; color: #102a43;">
          Demander un diagnostic collectivité
        </a>
      </div>
    </div>
  </article>

  <!-- Liens connexes -->
  <section class="py-12 border-t border-navy-100" style="background-color: #f0f4f8;">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-xl font-bold text-navy-900 mb-6">Ressources utiles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/expertises/pompe-a-chaleur/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Pompes à chaleur</p>
          <p class="text-xs text-navy-600 mt-1">Chauffage des bâtiments publics</p>
        </a>
        <a href="/dispositifs/demarches/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Démarches CEE</p>
          <p class="text-xs text-navy-600 mt-1">Étapes pour obtenir la prime</p>
        </a>
        <a href="/dispositifs/calcul-prime/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Calcul de prime</p>
          <p class="text-xs text-navy-600 mt-1">Estimez vos aides</p>
        </a>
        <a href="/secteurs/tertiaire/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Tertiaire</p>
          <p class="text-xs text-navy-600 mt-1">Décret tertiaire et BACS</p>
        </a>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
