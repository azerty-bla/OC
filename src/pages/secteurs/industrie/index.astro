---
import "../../../styles/global.css";
import Base from "../../../layouts/Base.astro";
---

<Base
  title="Performance énergétique industrie : solutions et aides CEE"
  description="Solutions d'efficacité énergétique pour l'industrie : process thermiques, air comprimé, moteurs, variateurs. Fiches CEE IND-UT-* et IND-BA-*, audit énergétique, ISO 50001."
  canonicalPath="/secteurs/industrie/"
>
  <!-- Breadcrumb -->
  <nav class="bg-white border-b border-navy-100" aria-label="Fil d'Ariane">
    <div class="mx-auto max-w-7xl px-6 py-3">
      <ol class="flex items-center gap-2 text-sm text-navy-600">
        <li><a href="/" class="hover:text-gold-600 no-underline">Accueil</a></li>
        <li class="before:content-['/'] before:mx-2"><a href="/secteurs/" class="hover:text-gold-600 no-underline">Secteurs</a></li>
        <li class="before:content-['/'] before:mx-2 text-navy-900 font-medium">Industrie</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: #f5c04a;">Marché industrie</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight max-w-4xl" style="color: #ffffff;">Performance énergétique industrie : solutions et aides CEE</h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl" style="color: #d9e2ec;">L'industrie concentre plus de 20 % de la consommation énergétique française. Oteria Conseil identifie et finance vos gisements d'économies via les CEE.</p>
    </div>
  </section>

  <!-- Article -->
  <article class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-3xl px-6">

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Les enjeux énergétiques de l'industrie</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Le secteur industriel est le deuxième consommateur d'énergie en France, avec des postes de consommation très spécifiques : chaleur de process (fours, séchoirs, étuves), production de froid, air comprimé, motorisation, éclairage de grands volumes, et chauffage de bâtiments industriels souvent mal isolés.
      </p>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Dans un contexte de hausse structurelle des coûts de l'énergie et de pression réglementaire croissante (audit énergétique obligatoire, taxonomie européenne, décret tertiaire pour les bureaux attenants), l'optimisation énergétique est devenue un enjeu de compétitivité industrielle, au-delà de la seule conformité environnementale.
      </p>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Le dispositif des <a href="/dispositifs/comprendre-les-cee/" class="text-gold-700 underline hover:text-gold-800">certificats d'économie d'énergie</a> offre un levier de financement particulièrement adapté à l'industrie : les fiches IND-* couvrent une large gamme d'équipements, et les volumes de <a href="/dispositifs/kwh-cumac/" class="text-gold-700 underline hover:text-gold-800">kWh cumac</a> générés par les projets industriels sont souvent considérables, justifiant des primes significatives.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Les principales opérations CEE pour l'industrie</h2>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Utilités industrielles (fiches IND-UT-*)</h3>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les fiches IND-UT couvrent les équipements transversaux présents dans la plupart des sites industriels :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>IND-UT-102 : Système de variation électronique de vitesse</strong> — Économies de 20 à 50 % sur la consommation des moteurs à charge variable (pompes, ventilateurs, compresseurs). Voir notre page <a href="/expertises/variateur-de-vitesse/" class="text-gold-700 underline hover:text-gold-800">variateur de vitesse</a>.</li>
        <li><strong>IND-UT-103 : Compresseur d'air</strong> — Remplacement par un compresseur à vitesse variable ou à vis haute performance. L'<a href="/expertises/air-comprime/" class="text-gold-700 underline hover:text-gold-800">air comprimé</a> représente 10 à 30 % de la facture électrique industrielle.</li>
        <li><strong>IND-UT-104 : Économiseur sur chaudière</strong> — Récupération de chaleur sur les fumées pour préchauffer l'eau d'alimentation. ROI typique : 2-3 ans.</li>
        <li><strong>IND-UT-113 : Récupération de chaleur sur compresseur</strong> — Valorisation de la chaleur fatale du compresseur pour le chauffage des locaux ou le préchauffage d'eau.</li>
        <li><strong>IND-UT-116 : Système de management de l'énergie (ISO 50001)</strong> — Mise en place d'un système de gestion conforme à la norme internationale.</li>
        <li><strong>IND-UT-117 : LED en industrie</strong> — Relamping des halls de production, quais et zones de stockage.</li>
        <li><strong>IND-UT-121 : Moteur premium IE3/IE4</strong> — Remplacement des moteurs anciens par des moteurs à haut rendement.</li>
        <li><strong>IND-UT-125 : Traitement d'eau de refroidissement</strong> — Optimisation des tours aéroréfrigérantes et circuits de refroidissement.</li>
      </ul>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Bâtiment industriel (fiches IND-BA-*)</h3>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les fiches IND-BA couvrent l'enveloppe et le chauffage des bâtiments industriels :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>IND-BA-110 : Déstratificateur / Brasseur d'air</strong> — Redistribution de la chaleur accumulée en hauteur dans les grands volumes. Voir notre page <a href="/expertises/destratificateur/" class="text-gold-700 underline hover:text-gold-800">destratificateur</a>.</li>
        <li><strong>IND-BA-112 : Isolation des murs</strong> — Isolation thermique par l'extérieur ou l'intérieur des bâtiments industriels.</li>
        <li><strong>IND-BA-113 : Isolation de toiture</strong> — Isolation sous bac acier ou en sur-toiture.</li>
      </ul>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Opérations spécifiques industrielles</h3>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Pour les projets de process qui ne correspondent à aucune fiche standardisée (récupération de chaleur fatale sur un four, optimisation d'un circuit vapeur complexe, cogénération), l'opération spécifique permet de valoriser des volumes de CEE très importants. Oteria Conseil dispose de l'expertise technique pour monter ces dossiers complexes, en collaboration avec des bureaux d'études spécialisés.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Les économies typiques par poste</h2>

      <div class="overflow-x-auto mb-8">
        <table class="w-full border-collapse text-sm text-navy-700">
          <thead>
            <tr class="bg-navy-50">
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Poste de consommation</th>
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Part de la facture</th>
              <th class="border border-navy-200 px-4 py-3 text-left font-semibold text-navy-900">Économie accessible</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border border-navy-200 px-4 py-3">Air comprimé</td>
              <td class="border border-navy-200 px-4 py-3">10-30 %</td>
              <td class="border border-navy-200 px-4 py-3">20-40 %</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">Motorisation</td>
              <td class="border border-navy-200 px-4 py-3">20-40 %</td>
              <td class="border border-navy-200 px-4 py-3">15-50 % (avec variateurs)</td>
            </tr>
            <tr>
              <td class="border border-navy-200 px-4 py-3">Chaleur process</td>
              <td class="border border-navy-200 px-4 py-3">30-60 %</td>
              <td class="border border-navy-200 px-4 py-3">10-25 %</td>
            </tr>
            <tr class="bg-navy-50">
              <td class="border border-navy-200 px-4 py-3">Éclairage</td>
              <td class="border border-navy-200 px-4 py-3">5-15 %</td>
              <td class="border border-navy-200 px-4 py-3">50-70 % (LED)</td>
            </tr>
            <tr>
              <td class="border border-navy-200 px-4 py-3">Chauffage bâtiment</td>
              <td class="border border-navy-200 px-4 py-3">10-20 %</td>
              <td class="border border-navy-200 px-4 py-3">20-40 %</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">Obligations réglementaires pour les industriels</h2>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Audit énergétique obligatoire</h3>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Les entreprises de plus de 250 salariés ou réalisant plus de 50 millions d'euros de chiffre d'affaires doivent réaliser un audit énergétique tous les 4 ans, conformément à la directive européenne 2012/27/UE transposée en droit français. Les entreprises certifiées ISO 50001 en sont exemptées. L'audit identifie les gisements d'économies et les investissements prioritaires — il constitue la base idéale pour un dossier CEE optimisé.
      </p>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">ISO 50001 et management de l'énergie</h3>

      <p class="text-navy-700 mb-4 leading-relaxed">
        La certification ISO 50001 structure la démarche d'amélioration continue de la performance énergétique. Elle est éligible aux CEE via la fiche IND-UT-116 et exempte de l'obligation d'audit. De nombreux industriels combinent la mise en place d'un SME (Système de Management de l'Énergie) avec un programme pluriannuel de travaux CEE.
      </p>

      <h3 class="text-xl font-semibold text-navy-800 mb-3">Décret tertiaire pour les bâtiments annexes</h3>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Les bâtiments tertiaires attenants aux sites industriels (bureaux, showrooms, R&D) de plus de 1 000 m² sont soumis au décret éco-énergie tertiaire. Les CEE financent les travaux nécessaires à la conformité. Voir notre page <a href="/secteurs/tertiaire/" class="text-gold-700 underline hover:text-gold-800">tertiaire</a>.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">L'expertise industrielle d'Oteria Conseil</h2>

      <p class="text-navy-700 mb-4 leading-relaxed">
        Notre accompagnement des industriels couvre l'ensemble de la chaîne de valeur énergétique :
      </p>

      <ul class="list-disc pl-6 text-navy-700 mb-6 space-y-2">
        <li><strong>Diagnostic multi-postes</strong> : identification systématique des gisements (utilités, process, bâtiment)</li>
        <li><strong>Optimisation du volume CEE</strong> : choix des fiches les plus avantageuses, regroupement d'opérations, montage d'opérations spécifiques si pertinent</li>
        <li><strong>Négociation avec les <a href="/dispositifs/obliges/" class="text-gold-700 underline hover:text-gold-800">obligés</a></strong> : mise en concurrence pour maximiser le prix de vos CEE</li>
        <li><strong>Gestion administrative complète</strong> : de la convention au versement de la prime</li>
        <li><strong>Coordination technique</strong> : interface avec vos bureaux d'études et installateurs</li>
      </ul>

      <p class="text-navy-700 mb-8 leading-relaxed">
        Nos références industrielles couvrent l'agroalimentaire, la métallurgie, la chimie, la plasturgie, le papier-carton, le textile et l'assemblage automobile. Quelle que soit votre filière, nous connaissons les équipements et les fiches applicables.
      </p>

      <!-- CTA -->
      <div class="rounded-lg p-8 mt-12 text-center" style="background-color: #f0f4f8;">
        <h3 class="text-xl font-bold text-navy-900 mb-3">Identifiez vos gisements d'économies industrielles</h3>
        <p class="text-navy-600 mb-6">Diagnostic gratuit de votre site. Estimation du potentiel CEE sous 48h.</p>
        <a href="/diagnostic-gratuit/" class="inline-flex items-center justify-center rounded-md px-8 py-4 text-base font-semibold no-underline transition-colors" style="background-color: #d4a024; color: #102a43;">
          Demander un diagnostic industriel
        </a>
      </div>
    </div>
  </article>

  <!-- Liens connexes -->
  <section class="py-12 border-t border-navy-100" style="background-color: #f0f4f8;">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-xl font-bold text-navy-900 mb-6">Expertises associées</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/expertises/air-comprime/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Air comprimé</p>
          <p class="text-xs text-navy-600 mt-1">Optimisation et CEE</p>
        </a>
        <a href="/expertises/variateur-de-vitesse/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Variateurs de vitesse</p>
          <p class="text-xs text-navy-600 mt-1">Motorisation efficace</p>
        </a>
        <a href="/expertises/destratificateur/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Destratificateurs</p>
          <p class="text-xs text-navy-600 mt-1">Confort grands volumes</p>
        </a>
        <a href="/dispositifs/comprendre-les-cee/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
          <p class="text-sm font-bold text-navy-900">Comprendre les CEE</p>
          <p class="text-xs text-navy-600 mt-1">Le dispositif expliqué</p>
        </a>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
