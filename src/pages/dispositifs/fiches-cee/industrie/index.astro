---
import "../../../../styles/global.css";
import ExpertisePage from "../../../../layouts/ExpertisePage.astro";
import FicheGrid from "../../../../components/FicheGrid.astro";

const journeyPages = [
  {label: "Vue d'ensemble", href: "/dispositifs/fiches-cee/"},
  {label: "Tertiaire", href: "/dispositifs/fiches-cee/tertiaire/"},
  {label: "Industrie", href: "/dispositifs/fiches-cee/industrie/"},
  {label: "Résidentiel", href: "/dispositifs/fiches-cee/residentiel/"},
  {label: "Agriculture", href: "/dispositifs/fiches-cee/agriculture/"},
  {label: "Transport", href: "/dispositifs/fiches-cee/transport/"},
];

const groups = [
  {
    title: "Bâtiment industriel",
    fiches: [
      {code: "IND-BA-110", title: "Déstratificateur / brasseur d'air", description: "Redistribution de la chaleur accumulée en hauteur dans les grands volumes."},
      {code: "IND-BA-112", title: "Isolation des murs", description: "Isolation thermique par l'extérieur ou l'intérieur des bâtiments industriels."},
      {code: "IND-BA-113", title: "Isolation de toiture", description: "Isolation sous bac acier ou en sur-toiture."},
    ],
  },
  {
    title: "Utilités et process",
    fiches: [
      {code: "IND-UT-102", title: "Variateur de vitesse", description: "Économies sur les moteurs à charge variable (pompes, ventilateurs, compresseurs)."},
      {code: "IND-UT-103", title: "Compresseur d'air performant", description: "Remplacement par un compresseur à vitesse variable ou à vis haute performance."},
      {code: "IND-UT-104", title: "Économiseur sur chaudière", description: "Récupération de chaleur sur les fumées pour préchauffer l'eau d'alimentation."},
      {code: "IND-UT-113", title: "Récupération de chaleur compresseur", description: "Valorisation de la chaleur fatale pour le chauffage des locaux."},
      {code: "IND-UT-116", title: "Système de management de l'énergie", description: "Mise en place d'un système de gestion conforme à la norme ISO 50001."},
      {code: "IND-UT-117", title: "LED en industrie", description: "Relamping des halls de production, quais et zones de stockage."},
      {code: "IND-UT-121", title: "Moteur premium IE3/IE4", description: "Remplacement des moteurs anciens par des moteurs à haut rendement."},
      {code: "IND-UT-122", title: "Séchage de l'air comprimé", description: "Prévention de la condensation et du colmatage dans les canalisations."},
      {code: "IND-UT-124", title: "Séquenceur multi-compresseurs", description: "Pilotage optimisé d'un parc de plusieurs compresseurs."},
      {code: "IND-UT-125", title: "Traitement d'eau de refroidissement", description: "Optimisation des tours aéroréfrigérantes et circuits de refroidissement."},
      {code: "IND-UT-130", title: "Récupération de chaleur (free cooling)", description: "Valorisation thermique sur installation d'air comprimé."},
      {code: "IND-UT-131", title: "Calorifugeage industriel", description: "Isolation des réseaux et points singuliers en industrie."},
      {code: "IND-UT-134", title: "Mesurage d'indicateurs énergétiques", description: "Comptage et supervision de la performance énergétique."},
      {code: "IND-UT-137", title: "Pompe à chaleur industrielle", description: "PAC haute température et récupération de chaleur fatale."},
      {code: "IND-UT-140", title: "Mise en veille automatique", description: "Arrêt automatique des compresseurs hors période d'utilisation."},
    ],
  },
];
---

<ExpertisePage
  title="Fiches CEE secteur industriel"
  description="Catalogue des fiches d'opérations standardisées CEE applicables à l'industrie : bâtiment industriel, utilités et process."
  canonical="/dispositifs/fiches-cee/industrie/"
  keyword="Fiches CEE industrie"
  cluster="Dispositifs CEE"
  breadcrumb={[{label: "Dispositifs CEE", href: "/dispositifs/"}, {label: "Fiches CEE", href: "/dispositifs/fiches-cee/"}]}
  journeyPages={journeyPages}
  relatedPages={[
    {title: "Air comprimé – industrie", href: "/expertises/air-comprime/industrie/", description: "Les opérations CEE sur réseaux d'air comprimé figurent parmi les fiches les plus utilisées en milieu industriel."},
    {title: "Variateur – industrie", href: "/expertises/variateur-de-vitesse/industrie/", description: "La fiche IND-UT-102 variateur est l'une des plus faciles à instruire et des plus rentables en industrie."},
    {title: "HP/BP flottante", href: "/expertises/hp-bp-flottante/", description: "Les fiches IND-FR et BAT-FR pour la HP/BP flottante génèrent des primes élevées sur les installations frigorifiques."},
  ]}
>
  <h2>Secteur industriel : 18 fiches CEE répertoriées</h2>

  <p>
    Le secteur <strong>IND-</strong> couvre les bâtiments industriels et les utilités de production. Les fiches ci-dessous sont classées par grande famille de travaux. Chaque fiche définit un forfait de <a href="/dispositifs/kwh-cumac/">kWh cumac</a> selon des critères techniques précis ; cette présentation n'a pas vocation à remplacer le texte officiel de la fiche.
  </p>

  <FicheGrid groups={groups} />

  <div class="expertise-highlight">
    <p>La fiche détaillée de chaque opération (conditions d'éligibilité exactes, formule de calcul, pièces justificatives) fera l'objet d'une prochaine mise à jour de ce site. Pour une étude personnalisée de votre projet, contactez nos experts.</p>
  </div>
</ExpertisePage>
