---
import "../../../../styles/global.css";
import ExpertisePage from "../../../../layouts/ExpertisePage.astro";
import FicheGrid from "../../../../components/FicheGrid.astro";

const journeyPages = [
  {label: "Vue d'ensemble", href: "/dispositifs/fiches-cee/"},
  {label: "Tertiaire", href: "/dispositifs/fiches-cee/tertiaire/"},
  {label: "Industrie", href: "/dispositifs/fiches-cee/industrie/"},
  {label: "Résidentiel", href: "/dispositifs/fiches-cee/residentiel/"},
  {label: "Agriculture", href: "/dispositifs/fiches-cee/agriculture/"},
  {label: "Transport", href: "/dispositifs/fiches-cee/transport/"},
];

const groups = [
  {
    title: "Enveloppe du bâtiment",
    fiches: [
      {code: "RES-EN-101", title: "Isolation de combles ou toiture-terrasse", description: "Réduction des déperditions thermiques par la toiture."},
      {code: "RES-EN-102", title: "Isolation des murs par l'extérieur", description: "ITE à fort impact, revalorisation complète de la façade."},
      {code: "RES-EN-103", title: "Isolation des planchers bas", description: "Isolation sur cave ou parking non chauffé."},
      {code: "RES-EN-104", title: "Menuiseries performantes", description: "Fenêtres et portes-fenêtres double ou triple vitrage."},
      {code: "RES-EN-107", title: "Isolation de points singuliers", description: "Traitement des liaisons et ponts thermiques."},
    ],
  },
  {
    title: "Chauffage collectif",
    fiches: [
      {code: "RES-CH-103", title: "Régulation du chauffage collectif", description: "Régulation et programmation du chauffage collectif."},
      {code: "RES-CH-104", title: "Pompe à chaleur collective", description: "PAC air/eau ou géothermie en habitat collectif."},
      {code: "RES-CH-107", title: "Chaudière collective performante", description: "Chaudière collective à haute performance."},
      {code: "RES-CH-108", title: "Émetteurs performants", description: "Radiateurs basse température."},
      {code: "RES-CH-109", title: "Calorifugeage des réseaux", description: "Isolation des réseaux de chauffage et d'eau chaude sanitaire."},
      {code: "RES-CH-110", title: "Robinets thermostatiques", description: "Régulation logement par logement du chauffage collectif."},
    ],
  },
  {
    title: "Éclairage",
    fiches: [
      {code: "RES-EC-104", title: "Éclairage des parties communes", description: "Éclairage LED avec détection de présence."},
    ],
  },
];
---

<ExpertisePage
  title="Fiches CEE secteur résidentiel"
  description="Catalogue des fiches d'opérations standardisées CEE applicables à l'habitat collectif : enveloppe, chauffage collectif et éclairage des parties communes."
  canonical="/dispositifs/fiches-cee/residentiel/"
  keyword="Fiches CEE résidentiel"
  cluster="Dispositifs CEE"
  breadcrumb={[{label: "Dispositifs CEE", href: "/dispositifs/"}, {label: "Fiches CEE", href: "/dispositifs/fiches-cee/"}]}
  journeyPages={journeyPages}
  relatedPages={[
    {title: "Pompe à chaleur – résidentiel", href: "/expertises/pompe-a-chaleur/residentiel/", description: "La PAC collective en copropriété génère les primes CEE les plus importantes du secteur résidentiel."},
    {title: "Isolation – résidentiel", href: "/expertises/isolation-thermique/residentiel/", description: "L'isolation des copropriétés (combles, murs, planchers) concentre l'essentiel des opérations CEE en résidentiel collectif."},
    {title: "VMC double flux", href: "/expertises/vmc-double-flux/", description: "La VMC double flux en copropriété est éligible aux CEE — prime cumulable avec l'isolation et la PAC."},
  ]}
>
  <h2>Secteur résidentiel : 12 fiches CEE répertoriées</h2>

  <p>
    Le secteur <strong>RES-</strong> couvre l'habitat collectif. Les fiches ci-dessous sont classées par grande famille de travaux. Chaque fiche définit un forfait de <a href="/dispositifs/kwh-cumac/">kWh cumac</a> selon des critères techniques précis ; cette présentation n'a pas vocation à remplacer le texte officiel de la fiche.
  </p>

  <FicheGrid groups={groups} />

  <div class="expertise-highlight">
    <p>La fiche détaillée de chaque opération (conditions d'éligibilité exactes, formule de calcul, pièces justificatives) fera l'objet d'une prochaine mise à jour de ce site. Pour une étude personnalisée de votre projet, contactez nos experts.</p>
  </div>
</ExpertisePage>
