---
import "../../../../styles/global.css";
import ExpertisePage from "../../../../layouts/ExpertisePage.astro";
import FicheGrid from "../../../../components/FicheGrid.astro";

const journeyPages = [
  {label: "Vue d'ensemble", href: "/dispositifs/fiches-cee/"},
  {label: "Tertiaire", href: "/dispositifs/fiches-cee/tertiaire/"},
  {label: "Industrie", href: "/dispositifs/fiches-cee/industrie/"},
  {label: "Résidentiel", href: "/dispositifs/fiches-cee/residentiel/"},
  {label: "Agriculture", href: "/dispositifs/fiches-cee/agriculture/"},
  {label: "Transport", href: "/dispositifs/fiches-cee/transport/"},
];

const groups = [
  {
    title: "Serres : enveloppe et équipements",
    fiches: [
      {code: "AGRI-EN-101", title: "Couverture de serre performante", description: "Double paroi ou matériaux à faible émissivité."},
      {code: "AGRI-EQ-101", title: "Pré-refroidisseur sur tank à lait", description: "Réduction de la consommation du groupe froid de 40 à 60 %."},
      {code: "AGRI-EQ-102", title: "Double écran piloté", description: "Double écran thermique piloté par ordinateur climatique."},
      {code: "AGRI-EQ-104", title: "Écrans latéraux de serre", description: "Écrans thermiques sur les parois latérales."},
      {code: "AGRI-EQ-107", title: "Parois latérales de serre", description: "Isolation des parois latérales de serre."},
      {code: "AGRI-EQ-108", title: "Double paroi gonflable", description: "Couverture double paroi gonflable, même surface."},
      {code: "AGRI-EQ-109", title: "Couverture performante", description: "Couverture de serre à faible déperdition."},
      {code: "AGRI-EQ-111", title: "Écran thermique simple", description: "Écran thermique sans ordinateur climatique requis."},
      {code: "AGRI-EQ-112", title: "Double paroi gonflable", description: "Couverture double paroi sans ordinateur climatique requis."},
    ],
  },
  {
    title: "Chauffage et process",
    fiches: [
      {code: "AGRI-TH-101", title: "Chaudière biomasse", description: "Remplacement d'une chaudière fioul/gaz pour le chauffage de serres."},
      {code: "AGRI-TH-103", title: "Récupération de chaleur sur séchoir", description: "Valorisation de la chaleur fatale pour le préchauffage de l'air."},
      {code: "AGRI-TH-104", title: "Écran thermique en serre", description: "Réduction des déperditions nocturnes de 30 à 50 %."},
      {code: "AGRI-TH-105", title: "Séchoir biomasse", description: "Remplacement d'un séchoir à combustible fossile."},
      {code: "AGRI-TH-106", title: "Isolation des bâtiments d'élevage", description: "Isolation des porcheries et poulaillers."},
      {code: "AGRI-TH-107", title: "Échangeur air-air", description: "Récupération de chaleur sur l'air extrait en bâtiment d'élevage."},
      {code: "AGRI-TH-108", title: "Pompe à chaleur pour serres", description: "Chauffage de serres par pompe à chaleur."},
      {code: "AGRI-TH-109", title: "Régulation climatique des serres", description: "Sondes, automates et gestion par zone."},
      {code: "AGRI-TH-113", title: "VMC double flux", description: "Récupération de chaleur 50 à 75 % en élevage et serres."},
      {code: "AGRI-TH-117", title: "Déshumidification", description: "Contrôle de l'humidité en serres et sites industriels."},
      {code: "AGRI-TH-119", title: "Déshumidification performante", description: "Pilotée par ordinateur climatique, volume de CEE élevé."},
    ],
  },
  {
    title: "Utilités",
    fiches: [
      {code: "AGRI-UT-101", title: "Régulation de l'irrigation", description: "Pilotage par sondes tensiométriques ou stations météo."},
      {code: "AGRI-UT-102", title: "Éclairage LED agricole", description: "Éclairage LED des bâtiments agricoles."},
      {code: "AGRI-UT-103", title: "Chauffage infrarouge localisé", description: "Chauffage radiant pour les porcelets et volailles."},
      {code: "AGRI-UT-104", title: "Variateur de vitesse", description: "Pompe d'irrigation ou ventilateurs de séchoir."},
    ],
  },
];
---

<ExpertisePage
  title="Fiches CEE secteur agricole"
  description="Catalogue des fiches d'opérations standardisées CEE applicables à l'agriculture : serres, chauffage, séchage, élevage et irrigation."
  canonical="/dispositifs/fiches-cee/agriculture/"
  keyword="Fiches CEE agriculture"
  cluster="Dispositifs CEE"
  breadcrumb={[{label: "Dispositifs CEE", href: "/dispositifs/"}, {label: "Fiches CEE", href: "/dispositifs/fiches-cee/"}]}
  journeyPages={journeyPages}
  relatedPages={[
    {title: "Isolation – agriculture", href: "/expertises/isolation-thermique/agriculture/", description: "L'isolation des serres et bâtiments d'élevage est l'une des opérations CEE les plus rentables en agriculture."},
    {title: "Pompe à chaleur – agriculture", href: "/expertises/pompe-a-chaleur/agriculture/", description: "La PAC agricole permet de chauffer serres et bâtiments d'élevage avec des économies de 50 % ou plus."},
    {title: "GTB – agriculture", href: "/expertises/gtb-gtc/agriculture/", description: "L'ordinateur climatique et la GTB agricole sont éligibles aux CEE pour la gestion automatisée des serres et bâtiments."},
  ]}
>
  <h2>Secteur agricole : 23 fiches CEE répertoriées</h2>

  <p>
    Le secteur <strong>AGRI-</strong> couvre les serres, bâtiments d'élevage, séchage et irrigation. Les fiches ci-dessous sont classées par grande famille de travaux. Chaque fiche définit un forfait de <a href="/dispositifs/kwh-cumac/">kWh cumac</a> selon des critères techniques précis ; cette présentation n'a pas vocation à remplacer le texte officiel de la fiche.
  </p>

  <FicheGrid groups={groups} />

  <div class="expertise-highlight">
    <p>La fiche détaillée de chaque opération (conditions d'éligibilité exactes, formule de calcul, pièces justificatives) fera l'objet d'une prochaine mise à jour de ce site. Pour une étude personnalisée de votre projet, contactez nos experts.</p>
  </div>
</ExpertisePage>
