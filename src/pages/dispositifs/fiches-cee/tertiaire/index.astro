---
import "../../../../styles/global.css";
import ExpertisePage from "../../../../layouts/ExpertisePage.astro";
import FicheGrid from "../../../../components/FicheGrid.astro";

const journeyPages = [
  {label: "Vue d'ensemble", href: "/dispositifs/fiches-cee/"},
  {label: "Tertiaire", href: "/dispositifs/fiches-cee/tertiaire/"},
  {label: "Industrie", href: "/dispositifs/fiches-cee/industrie/"},
  {label: "Résidentiel", href: "/dispositifs/fiches-cee/residentiel/"},
  {label: "Agriculture", href: "/dispositifs/fiches-cee/agriculture/"},
  {label: "Transport", href: "/dispositifs/fiches-cee/transport/"},
];

const groups = [
  {
    title: "Enveloppe du bâtiment",
    fiches: [
      {code: "BAT-EN-101", title: "Isolation de toiture", description: "Isolation par sur-toiture ou sous bac acier."},
      {code: "BAT-EN-102", title: "Isolation des murs par l'extérieur", description: "Isolation thermique par l'extérieur (ITE) des façades."},
      {code: "BAT-EN-103", title: "Isolation des planchers bas", description: "Suppression des remontées de froid sur local non chauffé."},
      {code: "BAT-EN-104", title: "Menuiseries performantes", description: "Fenêtres ou portes-fenêtres à isolation renforcée."},
      {code: "BAT-EN-105", title: "Isolation de l'enveloppe", description: "Travaux d'isolation thermique complémentaires en tertiaire."},
      {code: "BAT-EN-108", title: "Fermetures isolantes", description: "Volets ou stores isolants limitant les déperditions."},
      {code: "BAT-EN-109", title: "Protection solaire", description: "Réduction des apports solaires par vitrage à contrôle solaire."},
    ],
  },
  {
    title: "Équipements et éclairage",
    fiches: [
      {code: "BAT-EQ-111", title: "Moto-ventilateur EC", description: "Moto-ventilateur à commutation électronique."},
      {code: "BAT-EQ-123", title: "Moto-variateur synchrone", description: "Moteur à aimants permanents IE5 avec variateur intégré."},
      {code: "BAT-EQ-127", title: "Relamping LED", description: "Remplacement des luminaires par un éclairage LED performant."},
      {code: "BAT-EQ-133", title: "Gestion de l'éclairage", description: "Détection de présence et gradation automatique."},
    ],
  },
  {
    title: "Chauffage, ventilation et climatisation",
    fiches: [
      {code: "BAT-TH-104", title: "Robinets thermostatiques", description: "Régulation pièce par pièce du chauffage tertiaire."},
      {code: "BAT-TH-112", title: "Variateur de vitesse CVC", description: "Variation électronique de vitesse sur pompage et ventilation."},
      {code: "BAT-TH-163", title: "Pompe à chaleur", description: "Remplacement du chauffage par une PAC air/eau."},
      {code: "BAT-TH-116", title: "GTB / GTC classe A ou B", description: "Gestion technique du bâtiment, conformité décret BACS."},
      {code: "BAT-TH-126", title: "VMC double flux", description: "Ventilation double flux avec récupération de chaleur."},
      {code: "BAT-TH-140", title: "Ventilation à débit variable", description: "Système de ventilation adapté aux besoins réels."},
      {code: "BAT-TH-142", title: "Déstratificateur d'air", description: "Brassage d'air pour homogénéiser la température en hauteur."},
      {code: "BAT-TH-148", title: "Chauffe-eau thermodynamique", description: "Production d'eau chaude sanitaire par pompe à chaleur."},
      {code: "BAT-TH-155", title: "Ventilo-convecteurs performants", description: "Émetteurs de chaleur/froid à haute efficacité."},
      {code: "BAT-TH-162", title: "Système géothermique complet", description: "Forage, PAC et réseau de distribution géothermique."},
      {code: "BAT-TH-163", title: "Pompe à chaleur air-eau", description: "PAC performante en vigueur depuis avril 2026."},
      {code: "BAT-TH-164", title: "Pompe à chaleur eau-eau", description: "PAC performante en vigueur depuis janvier 2026."},
    ],
  },
];
---

<ExpertisePage
  title="Fiches CEE secteur tertiaire"
  description="Catalogue des fiches d'opérations standardisées CEE applicables aux bâtiments tertiaires : isolation, équipements, chauffage, ventilation et climatisation."
  canonical="/dispositifs/fiches-cee/tertiaire/"
  keyword="Fiches CEE tertiaire"
  cluster="Dispositifs CEE"
  breadcrumb={[{label: "Dispositifs CEE", href: "/dispositifs/"}, {label: "Fiches CEE", href: "/dispositifs/fiches-cee/"}]}
  journeyPages={journeyPages}
  relatedPages={[
    {title: "Pompe à chaleur – tertiaire", href: "/expertises/pompe-a-chaleur/tertiaire/", description: "La PAC tertiaire est l'une des opérations CEE les plus récentes et les plus rentables dans les bureaux et commerces."},
    {title: "Isolation – tertiaire", href: "/expertises/isolation-thermique/tertiaire/", description: "Les fiches BAT-EN d'isolation couvrent murs, toitures et planchers des bâtiments à usage professionnel."},
    {title: "GTB – tertiaire", href: "/expertises/gtb-gtc/tertiaire/", description: "La GTB tertiaire (BAT-TH-116) est éligible aux CEE pour la supervision des équipements de chauffage et climatisation."},
  ]}
>
  <h2>Secteur tertiaire : 26 fiches CEE répertoriées</h2>

  <p>
    Le secteur <strong>BAT-</strong> couvre les bâtiments de bureaux, commerces, entrepôts et établissements de santé. Les fiches ci-dessous sont classées par grande famille de travaux. Chaque fiche définit un forfait de <a href="/dispositifs/kwh-cumac/">kWh cumac</a> selon des critères techniques précis ; cette présentation n'a pas vocation à remplacer le texte officiel de la fiche.
  </p>

  <FicheGrid groups={groups} />

  <div class="expertise-highlight">
    <p>La fiche détaillée de chaque opération (conditions d'éligibilité exactes, formule de calcul, pièces justificatives) fera l'objet d'une prochaine mise à jour de ce site. Pour une étude personnalisée de votre projet, contactez nos experts.</p>
  </div>
</ExpertisePage>
