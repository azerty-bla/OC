<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) { const ctx = canvas.getContext('2d'); var particles = []; const PARTICLE_COUNT = 55; const CONNECTION_DIST = 150; function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; } function init() { resize(); particles = []; for (let i = 0; i < PARTICLE_COUNT; i++) { particles.push({ x: Math.random() * canvas.width, y: Math.random() * canvas.height, vx: (Math.random() - 0.5) * 0.5, vy: (Math.random() - 0.5) * 0.3 }); } } function draw() { ctx.clearRect(0, 0, canvas.width, canvas.height); for (let i = 0; i < particles.length; i++) { const p = particles[i]; p.x += p.vx; p.y += p.vy; if (p.x < 0 || p.x > canvas.width) p.vx *= -1; if (p.y < 0 || p.y > canvas.height) p.vy *= -1; ctx.beginPath(); ctx.arc(p.x, p.y, 2, 0, Math.PI * 2); ctx.fillStyle = '#d4a024'; ctx.fill(); for (let j = i + 1; j < particles.length; j++) { const p2 = particles[j]; const dist = Math.hypot(p.x - p2.x, p.y - p2.y); if (dist < CONNECTION_DIST) { ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p2.x, p2.y); ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`; ctx.lineWidth = 0.7; ctx.stroke(); } } } requestAnimationFrame(draw); } init(); draw(); window.addEventListener('resize', resize); }
</script>
