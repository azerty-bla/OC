          <p class="text-xs text-navy-600 mt-1">Cadre juridique</p>
        </a>
        <a href="/dispositifs/glossaire/" class="block bg-white rounded-lg p-5 border border-navy-100 hover:border-gold-300 hover:shadow-md transition-all no-underline">
