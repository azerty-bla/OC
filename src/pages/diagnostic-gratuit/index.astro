    </div>
  </section>

  <!-- Main content: two columns -->
  <section class="py-12 md:py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">

        <!-- Right column: Sticky form (order-first on mobile) -->
