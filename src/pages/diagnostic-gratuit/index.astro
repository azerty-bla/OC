---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";
---

<Base
  title="Diagnostic gratuit – Performance énergétique et CEE"
  description="Demandez votre diagnostic énergétique gratuit. Réponse sous 48h, sans engagement. 19 ans d'expertise CEE au service de votre entreprise."
  canonicalPath="/diagnostic-gratuit/"
>
  <!-- Compact hero -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-12 md:py-16 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #f5c04a;">Diagnostic gratuit</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight max-w-3xl mx-auto" style="color: #ffffff; font-family: var(--font-heading);">Votre diagnostic énergétique gratuit</h1>
      <p class="mt-4 text-lg leading-relaxed max-w-2xl mx-auto" style="color: #d9e2ec;">Recevez sous 48h une première analyse de vos gisements d'économies et des aides mobilisables.</p>
    </div>
  </section>

  <!-- Main content: two columns -->
  <section class="py-12 md:py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">

        <!-- Right column: Sticky form (order-first on mobile) -->
        <div class="lg:col-span-5 order-first lg:order-last">
          <div class="lg:sticky lg:top-24">
            <div class="bg-white rounded-lg p-8 md:p-10 border shadow-lg" style="border-color: #d9e2ec; box-shadow: 0 10px 40px -10px rgba(16, 42, 67, 0.12);">
              <h2 class="text-xl font-bold mb-1" style="color: #102a43; font-family: var(--font-heading);">Demandez votre diagnostic</h2>
              <p class="text-sm mb-8" style="color: #486581;">Gratuit et sans engagement</p>

              <form action="/diagnostic-gratuit/" method="GET" class="space-y-5">
                <div>
                  <label for="raison_sociale" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Raison sociale</label>
                  <input
                    type="text"
                    id="raison_sociale"
                    name="raison_sociale"
                    required
                    placeholder="Nom de votre entreprise"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="nom" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Nom</label>
                  <input
                    type="text"
                    id="nom"
                    name="nom"
                    required
                    placeholder="Votre nom"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="email" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Email professionnel</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="vous@entreprise.fr"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="telephone" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Telephone</label>
                  <input
                    type="tel"
                    id="telephone"
                    name="telephone"
                    required
                    placeholder="01 23 45 67 89"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  />
                </div>

                <div>
                  <label for="message" class="block text-sm font-medium mb-1.5" style="color: #334e68;">Message</label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="4"
                    placeholder="Type de chauffage, surface du/des batiments, preference horaire de contact"
                    class="w-full rounded-md border px-4 py-3 text-sm outline-none transition-colors resize-none"
                    style="border-color: #bcccdc; color: #102a43; background-color: #ffffff;"
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full rounded-md px-6 py-4 text-base font-semibold transition-colors cursor-pointer border-none"
                  style="background-color: #d4a024; color: #102a43;"
                >
                  Envoyer ma demande
                </button>
              </form>

              <p class="mt-5 text-xs text-center leading-relaxed" style="color: #486581;">
                <svg class="inline-block w-3.5 h-3.5 mr-1 align-text-bottom" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="color: #486581;"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
                Vos donnees sont protegees. <a href="/politique-confidentialite/" class="underline" style="color: #486581;">Politique de confidentialite</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Left column: Content -->
        <div class="lg:col-span-7 order-last lg:order-first">

          <!-- Trust signals checklist -->
          <div class="flex flex-wrap gap-x-6 gap-y-3 mb-10">
            <span class="flex items-center gap-2 text-sm font-medium" style="color: #334e68;">
              <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs" style="background-color: #f0f4f8; color: #276749;">&#10003;</span>
              Sans engagement
            </span>
            <span class="flex items-center gap-2 text-sm font-medium" style="color: #334e68;">
              <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs" style="background-color: #f0f4f8; color: #276749;">&#10003;</span>
              Reponse sous 48h
            </span>
            <span class="flex items-center gap-2 text-sm font-medium" style="color: #334e68;">
              <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs" style="background-color: #f0f4f8; color: #276749;">&#10003;</span>
              19 ans d'expertise
            </span>
            <span class="flex items-center gap-2 text-sm font-medium" style="color: #334e68;">
              <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs" style="background-color: #f0f4f8; color: #276749;">&#10003;</span>
              Conseil independant
            </span>
          </div>

          <!-- How it works -->
          <div class="mb-14">
            <h2 class="text-xl md:text-2xl font-bold mb-8" style="color: #102a43; font-family: var(--font-heading);">Comment ca marche</h2>
            <div class="space-y-8">
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold" style="background-color: #102a43; color: #f5c04a;">1</div>
                <div>
                  <h3 class="text-base font-bold mb-1" style="color: #243b53;">Decrivez votre situation</h3>
                  <p class="text-sm leading-relaxed" style="color: #486581;">Remplissez le formulaire avec les informations de base sur vos batiments et equipements. 2 minutes suffisent.</p>
                </div>
              </div>
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold" style="background-color: #102a43; color: #f5c04a;">2</div>
                <div>
                  <h3 class="text-base font-bold mb-1" style="color: #243b53;">Nous analysons votre potentiel</h3>
                  <p class="text-sm leading-relaxed" style="color: #486581;">Un consultant dedie etudie votre dossier, identifie les gisements d'economies et les dispositifs CEE applicables.</p>
                </div>
              </div>
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold" style="background-color: #102a43; color: #f5c04a;">3</div>
                <div>
                  <h3 class="text-base font-bold mb-1" style="color: #243b53;">Recevez vos recommandations</h3>
                  <p class="text-sm leading-relaxed" style="color: #486581;">Sous 48h, vous recevez une synthese claire : economies estimees, primes mobilisables et prochaines etapes concretes.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Social proof / Testimonials -->
          <div class="mb-14">
            <h2 class="text-xl md:text-2xl font-bold mb-8" style="color: #102a43; font-family: var(--font-heading);">Ils nous ont fait confiance</h2>
            <div class="space-y-6">
              <blockquote class="rounded-lg p-6 border" style="background-color: #f0f4f8; border-color: #d9e2ec;">
                <p class="text-sm leading-relaxed italic mb-4" style="color: #334e68;">&laquo; Oteria Conseil nous a permis d'identifier plus de 45 000 euros de primes CEE sur notre programme de renovation. Un accompagnement clair et professionnel du debut a la fin. &raquo;</p>
                <footer class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold" style="background-color: #243b53; color: #f5c04a;">DL</div>
                  <div>
                    <p class="text-sm font-semibold" style="color: #243b53;">Directeur technique</p>
                    <p class="text-xs" style="color: #486581;">Groupe industriel, Ile-de-France</p>
                  </div>
                </footer>
              </blockquote>
              <blockquote class="rounded-lg p-6 border" style="background-color: #f0f4f8; border-color: #d9e2ec;">
                <p class="text-sm leading-relaxed italic mb-4" style="color: #334e68;">&laquo; Reponse rapide, conseil independant, et un vrai gain de temps sur les demarches administratives. Je recommande sans hesiter. &raquo;</p>
                <footer class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold" style="background-color: #243b53; color: #f5c04a;">MR</div>
                  <div>
                    <p class="text-sm font-semibold" style="color: #243b53;">Responsable maintenance</p>
                    <p class="text-xs" style="color: #486581;">PME tertiaire, Lyon</p>
                  </div>
                </footer>
              </blockquote>
            </div>
          </div>

          <!-- Mini FAQ -->
          <div>
            <h2 class="text-xl md:text-2xl font-bold mb-8" style="color: #102a43; font-family: var(--font-heading);">Questions frequentes</h2>
            <div class="space-y-6">
              <details class="group rounded-lg border overflow-hidden" style="border-color: #d9e2ec;">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-sm font-semibold select-none" style="color: #243b53;">
                  Le diagnostic est-il vraiment gratuit ?
                  <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-4 text-sm leading-relaxed" style="color: #486581;">
                  Oui, le diagnostic initial est entierement gratuit et sans engagement. Il vous permet d'obtenir une premiere estimation de vos economies potentielles et des primes CEE mobilisables.
                </div>
              </details>

              <details class="group rounded-lg border overflow-hidden" style="border-color: #d9e2ec;">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-sm font-semibold select-none" style="color: #243b53;">
                  Combien de temps prend le diagnostic ?
                  <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-4 text-sm leading-relaxed" style="color: #486581;">
                  Vous recevez un retour sous 48h ouvrees. Le formulaire ne prend que 2 minutes a remplir. Un consultant vous recontacte ensuite pour affiner l'analyse si necessaire.
                </div>
              </details>

              <details class="group rounded-lg border overflow-hidden" style="border-color: #d9e2ec;">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-sm font-semibold select-none" style="color: #243b53;">
                  Quels types de batiments sont concernes ?
                  <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-4 text-sm leading-relaxed" style="color: #486581;">
                  Nous intervenons sur tous les batiments tertiaires et industriels : bureaux, entrepots, commerces, sites de production, etablissements de sante, collectivites, etc.
                </div>
              </details>

              <details class="group rounded-lg border overflow-hidden" style="border-color: #d9e2ec;">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-sm font-semibold select-none" style="color: #243b53;">
                  Êtes-vous indépendant des fournisseurs ?
                  <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-4 text-sm leading-relaxed" style="color: #486581;">
                  Absolument. Oteria Conseil est un cabinet indépendant. Nous n'avons aucun lien commercial avec les fournisseurs d'énergie ou les installateurs. Notre conseil est 100% objectif.
                </div>
              </details>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Related pages -->
  <section class="py-10 border-t" style="background-color: #f0f4f8; border-color: #d9e2ec;">
    <div class="mx-auto max-w-7xl px-6">
      <p class="text-sm mb-4" style="color: #486581;">Découvrir nos services :</p>
      <div class="flex flex-wrap gap-4">
        <a href="/expertises/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Nos expertises</a>
        <a href="/dispositifs/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Dispositifs CEE</a>
        <a href="/achat-energie/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Courtage énergie</a>
        <a href="/mobilite-electrique/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Bornes IRVE</a>
        <a href="/qui-sommes-nous/" class="text-sm font-semibold no-underline" style="color: #7a530d;">Qui sommes-nous</a>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
