---
import "../../styles/global.css";
import Base from "../../layouts/Base.astro";
---

<Base
  title="Qui sommes-nous – Cabinet de conseil en performance énergétique"
  description="Oteria Conseil : 19 ans d'expertise en CEE et performance énergétique. Industrie, tertiaire, collectivités. Un cabinet indépendant, orienté résultats."
  canonicalPath="/qui-sommes-nous/"
>
  <!-- Hero -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: #f5c04a;">Qui sommes-nous</p>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight" style="color: #ffffff;">Un cabinet indépendant au service de votre performance énergétique</h1>
          <p class="mt-6 text-lg leading-relaxed" style="color: #d9e2ec;">Notre équipe cumule 19 ans d'expérience au service des entreprises, collectivités et industriels dans l'optimisation de leurs consommations et la mobilisation des aides financières.</p>
          <div class="mt-8 flex items-center gap-6">
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div><span class="text-sm" style="color: #9fb3c8;">Diagnostic gratuit</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div><span class="text-sm" style="color: #9fb3c8;">Réponse sous 48h</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background-color: #48bb78;"></div><span class="text-sm" style="color: #9fb3c8;">19 ans d'expertise</span></div>
          </div>
        </div>
        <div class="lg:col-span-2">
          <div class="bg-white rounded-lg p-6 shadow-2xl hero-form">
            <p class="text-base font-bold text-navy-900 mb-1" style="font-family: var(--font-heading)">Diagnostic gratuit</p>
            <p class="text-xs text-navy-600 mb-4">Étude personnalisée sans engagement</p>
            <form action="/diagnostic-gratuit/" method="GET" class="space-y-3">
              <div class="grid grid-cols-2 gap-3">
                <input type="text" name="raison_sociale" required placeholder="Raison sociale *" class="w-full rounded-md border border-navy-200 px-3 py-2.5 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none" />
                <input type="text" name="nom" required placeholder="Nom *" class="w-full rounded-md border border-navy-200 px-3 py-2.5 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <input type="email" name="email" required placeholder="Email *" class="w-full rounded-md border border-navy-200 px-3 py-2.5 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none" />
                <input type="tel" name="telephone" required placeholder="Téléphone *" class="w-full rounded-md border border-navy-200 px-3 py-2.5 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none" />
              </div>
              <textarea name="message" rows="2" placeholder="Message : type de chauffage, surface, préférence horaire de contact *" class="w-full rounded-md border border-navy-200 px-3 py-2.5 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none resize-none"></textarea>
              <button type="submit" class="w-full rounded-md px-4 py-2.5 text-sm font-semibold cursor-pointer border-none" style="background-color: #d4a024; color: #102a43;">Demander un diagnostic →</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Notre histoire -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #7a530d;">Notre cabinet</p>
          <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-6">19 ans d'expertise au coeur de la transition énergétique</h2>
          <p class="text-navy-600 leading-relaxed mb-4">Oteria Conseil est un cabinet de conseil spécialisé en performance énergétique et dispositifs de financement. Depuis notre création, nous avons accompagné des centaines d'entreprises dans la réduction de leurs consommations d'énergie et l'obtention de primes CEE substantielles.</p>
          <p class="text-navy-600 leading-relaxed mb-4">Notre positionnement est celui d'un tiers de confiance indépendant : nous ne sommes ni fournisseur d'énergie, ni installateur. Cette indépendance nous permet de recommander systématiquement les solutions les plus adaptées à chaque contexte, sans conflit d'intérêt.</p>
          <p class="text-navy-600 leading-relaxed">Notre expertise couvre l'ensemble de la chaîne de valeur : diagnostic, identification des opérations éligibles, montage administratif, négociation avec les obligés, suivi des travaux et versement des primes.</p>
        </div>
        <div class="bg-navy-50 rounded-lg p-8 border border-navy-100">
          <h3 class="text-lg font-bold text-navy-900 mb-6">Oteria Conseil en chiffres</h3>
          <div class="space-y-6">
            <div>
              <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">19 ans</p>
              <p class="text-sm text-navy-600 mt-1">D'expertise en performance énergétique et CEE</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">14 M&euro;</p>
              <p class="text-sm text-navy-600 mt-1">De primes CEE obtenues pour nos clients</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">30 %</p>
              <p class="text-sm text-navy-600 mt-1">D'économies moyennes sur la facture énergétique</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">48h</p>
              <p class="text-sm text-navy-600 mt-1">Délai de réponse pour chaque demande</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Valeurs -->
  <section class="py-16 md:py-24" style="background-color: #f0f4f8;">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #7a530d;">Nos engagements</p>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-900">Les valeurs qui guident notre accompagnement</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-lg p-8 border border-navy-100">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-navy-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-3">Expertise</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Une connaissance approfondie des mécanismes CEE, de la réglementation énergétique et des solutions techniques. Notre équipe maîtrise les fiches standardisées et les évolutions du dispositif.</p>
        </div>
        <div class="bg-white rounded-lg p-8 border border-navy-100">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-navy-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-3">Transparence</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Un conseil indépendant, sans lien commercial avec les fournisseurs ou installateurs. Nous vous recommandons les solutions les plus pertinentes pour votre situation, en toute objectivité.</p>
        </div>
        <div class="bg-white rounded-lg p-8 border border-navy-100">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-navy-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-3">Résultats</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Un engagement sur des résultats concrets et mesurables : montant des primes obtenues, économies réalisées, délais de mise en oeuvre. Nous rendons des comptes à chaque étape.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Secteurs -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-12">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #7a530d;">Nos secteurs</p>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-900">Des interventions dans tous les secteurs professionnels</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="rounded-lg p-6 border border-navy-100">
          <h3 class="text-base font-bold text-navy-900 mb-3">Industrie</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Process industriels, air comprimé, moteurs et variateurs, récupération de chaleur. Des gisements d'économies importants avec des primes CEE élevées.</p>
        </div>
        <div class="rounded-lg p-6 border border-navy-100">
          <h3 class="text-base font-bold text-navy-900 mb-3">Tertiaire</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Bureaux, commerces, hôtellerie, santé. CVC, éclairage, GTB et conformité au décret tertiaire. Un accompagnement de la conception au suivi.</p>
        </div>
        <div class="rounded-lg p-6 border border-navy-100">
          <h3 class="text-base font-bold text-navy-900 mb-3">Collectivités</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Bâtiments publics, éclairage extérieur, équipements sportifs et culturels. Maîtrise budgétaire et exemplarité environnementale.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24" style="background-color: #243b53;">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-6" style="color: #ffffff;">Discutons de votre projet énergétique</h2>
      <p class="text-lg mb-8" style="color: #d9e2ec;">Diagnostic gratuit, réponse sous 48h, sans engagement.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/diagnostic-gratuit/" class="inline-flex items-center justify-center rounded-md px-8 py-4 text-base font-semibold no-underline transition-colors" style="background-color: #d4a024; color: #102a43;">
          Demander un diagnostic gratuit
        </a>
        <a href="/expertises/" class="inline-flex items-center justify-center rounded-md px-8 py-4 text-base font-semibold no-underline transition-colors border" style="border-color: #627d98; color: #d9e2ec;">
          Découvrir nos expertises
        </a>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    var particles = [];
    const PARTICLE_COUNT = 55;
    const CONNECTION_DIST = 150;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#d4a024';
        ctx.fill();
        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < CONNECTION_DIST) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(212, 160, 36, ${1 - dist / CONNECTION_DIST})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    init();
    draw();
    window.addEventListener('resize', resize);
  }
</script>
