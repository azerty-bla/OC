        </div>
        <!-- Thomas -->
        <div class="group relative rounded-2xl overflow-hidden" style="background: linear-gradient(135deg, #102a43 0%, #243b53 100%);">
          <div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-10" style="background: #f5c04a; transform: translate(30%, -30%);"></div>
          <div class="relative p-10 flex flex-col items-center text-center">
            <div class="w-24 h-24 rounded-full flex items-center justify-center mb-6 text-3xl font-bold ring-4" style="background-color: #1a3a5c; color: #f5c04a; font-family: var(--font-heading); ring-color: rgba(245, 192, 74, 0.3);">TR</div>
