---
import "../styles/global.css";
import Base from "../layouts/Base.astro";
---

<Base
  title="Oteria Conseil – Performance énergétique et aides CEE pour les professionnels"
  description="Cabinet de conseil en performance énergétique. Accompagnement CEE, courtage énergie et bornes IRVE pour l'industrie, le tertiaire et les collectivités."
>
  <!-- HERO -->
  <section class="relative overflow-hidden" style="background-color: #102a43;">
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-[0.35]"></canvas>
    <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest mb-6" style="color: #f5c04a;">
            19 ans d'expertise en performance énergétique
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-5xl font-bold leading-tight" style="color: #ffffff;">
            Réduisez vos coûts énergétiques.<br />
            <span style="color: #f5c04a;">Maximisez vos aides.</span>
          </h1>
          <p class="mt-8 text-lg leading-relaxed" style="color: #d9e2ec;">
            Oteria Conseil accompagne les professionnels dans l'optimisation de leur performance
            énergétique : certificats d'économie d'énergie, courtage, bornes de recharge.
          </p>
        </div>
        <div class="bg-white rounded-lg p-8 shadow-xl">
          <p class="text-lg font-bold text-navy-900 mb-1" style="font-family: var(--font-heading)">Diagnostic gratuit</p>
          <p class="text-sm text-navy-600 mb-6">Réponse sous 48h</p>
          <form action="/diagnostic-gratuit/" method="GET" class="space-y-4">
            <input type="text" name="raison_sociale" required placeholder="Raison sociale *" class="w-full rounded-md border border-navy-200 px-4 py-3 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none transition-colors" />
            <input type="text" name="nom" required placeholder="Nom *" class="w-full rounded-md border border-navy-200 px-4 py-3 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none transition-colors" />
            <input type="email" name="email" required placeholder="Email professionnel *" class="w-full rounded-md border border-navy-200 px-4 py-3 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none transition-colors" />
            <input type="tel" name="telephone" required placeholder="Téléphone *" class="w-full rounded-md border border-navy-200 px-4 py-3 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none transition-colors" />
            <textarea name="message" required rows="3" placeholder="Message : type de chauffage, surface du/des bâtiments, préférence horaire de contact *" class="w-full rounded-md border border-navy-200 px-4 py-3 text-sm text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:ring-1 focus:ring-gold-500 outline-none transition-colors resize-none"></textarea>
            <button type="submit" class="w-full rounded-md px-6 py-3.5 text-base font-semibold transition-colors cursor-pointer" style="background-color: #d4a024; color: #102a43;">
              Demander mon diagnostic
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- INDICATEURS DE CONFIANCE -->
  <section class="border-b border-navy-100 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">19 ans</p>
          <p class="text-sm text-navy-600 mt-1">D'expertise CEE</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">14M€</p>
          <p class="text-sm text-navy-600 mt-1">De primes CEE obtenues</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">30%</p>
          <p class="text-sm text-navy-600 mt-1">D'économies moyennes</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-navy-900" style="font-family: var(--font-heading)">48h</p>
          <p class="text-sm text-navy-600 mt-1">Délai de réponse</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERTISES -->
  <section class="bg-navy-50 py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #7a530d;">Nos domaines d'intervention</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900">Des expertises concrètes, des résultats mesurables</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <a href="/expertises/destratificateur/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">Destratificateurs</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Réduction de 20 à 30 % du chauffage par homogénéisation thermique. Prime CEE incluse.</p>
        </a>
        <a href="/expertises/vmc-double-flux/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">VMC double flux</h3>
          <p class="text-sm text-navy-600 leading-relaxed">Ventilation haut rendement avec récupération de chaleur. Aide CEE et dimensionnement.</p>
        </a>
        <a href="/expertises/variateur-de-vitesse/" class="group block bg-white rounded-lg p-8 border border-navy-100 hover:border-gold-300 hover:shadow-lg transition-all no-underline">
          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
          </div>
