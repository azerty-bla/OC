          <div class="w-12 h-12 rounded-md bg-navy-100 flex items-center justify-center mb-5 group-hover:bg-gold-100 transition-colors">
            <svg class="w-6 h-6 text-navy-700 group-hover:text-gold-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" /></svg>
