      <div class="stat-number">25%</div>
      <div class="stat-label">Économies attendues</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">15-22 k€</div>
      <div class="stat-label">Prime CEE</div>
    </div>
    <div class="stat-item">
