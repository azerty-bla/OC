    {title: "FAQ variateur", href: "/expertises/variateur-de-vitesse/faq/", description: "Questions fréquentes sur le variateur de vitesse et son application sur les compresseurs d'air comprimé."},
    {title: "FAQ GTB", href: "/expertises/gtb-gtc/faq/", description: "Questions sur la GTB industrielle et la supervision de vos réseaux d'air comprimé."},
  ]}
>
